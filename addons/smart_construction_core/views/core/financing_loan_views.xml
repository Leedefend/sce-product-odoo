<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_financing_loan_search" model="ir.ui.view">
            <field name="name">sc.financing.loan.search</field>
            <field name="model">sc.financing.loan</field>
            <field name="arch" type="xml">
                <search string="借款办理">
                    <field name="name"/>
                    <field name="document_no"/>
                    <field name="project_id"/>
                    <field name="operation_strategy"/>
                    <field name="partner_id"/>
                    <field name="business_category_id"/>
                    <field name="purpose"/>
                    <filter string="贷款登记" name="loan_registration" domain="[('loan_type', '=', 'loan_registration')]"/>
                    <filter string="借款申请" name="borrowing_request" domain="[('loan_type', '=', 'borrowing_request')]"/>
                    <filter string="已确认" name="state_confirmed" domain="[('state', 'in', ['confirmed', 'legacy_confirmed'])]"/>
                    <filter string="已完成" name="state_done" domain="[('state', '=', 'done')]"/>
                    <filter string="公司直营" name="operation_direct" domain="[('operation_strategy', '=', 'direct')]"/>
                    <filter string="联营项目" name="operation_joint" domain="[('operation_strategy', '=', 'joint')]"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按经营策略" name="group_operation_strategy" context="{'group_by': 'operation_strategy'}"/>
                    <filter string="按单位" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="按业务分类" name="group_business_category" context="{'group_by': 'business_category_id'}"/>
                    <filter string="按类型" name="group_type" context="{'group_by': 'loan_type'}"/>
                    <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="按日期" name="group_date" context="{'group_by': 'document_date'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_financing_loan_tree" model="ir.ui.view">
            <field name="name">sc.financing.loan.tree</field>
            <field name="model">sc.financing.loan</field>
            <field name="arch" type="xml">
                <tree string="借款办理">
                    <field name="name"/>
                    <field name="document_date"/>
                    <field name="document_no"/>
                    <field name="loan_flow_label"/>
                    <field name="project_id"/>
                    <field name="operation_strategy"/>
                    <field name="partner_id"/>
                    <field name="business_category_id" optional="show"/>
                    <field name="amount" string="借款金额" sum="金额"/>
                    <field name="financing_loan_request_department" optional="hide"/>
                    <field name="financing_loan_budget_included" optional="hide"/>
                    <field name="financing_loan_request_amount" optional="hide"/>
                    <field name="financing_loan_approved_amount" optional="hide"/>
                    <field name="due_date"/>
                    <field name="purpose"/>
                    <field name="loan_type" optional="hide"/>
                    <field name="direction" optional="hide"/>
                    <field name="rate_label"/>
                    <field name="extra_ref"/>
                    <field name="extra_label"/>
                    <field name="creator_name"/>
                    <field name="created_time"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_financing_loan_form" model="ir.ui.view">
            <field name="name">sc.financing.loan.form</field>
            <field name="model">sc.financing.loan</field>
            <field name="arch" type="xml">
                <form string="借款办理">
                    <header>
                        <button name="action_confirm" string="提交审批" type="object" class="btn-primary"
                                invisible="state != 'draft' or validation_status in ('waiting', 'pending', 'validated')"/>
                        <button name="validate_tier" string="审批通过" type="object" class="btn-primary"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="reject_tier" string="审批驳回" type="object"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="action_done" string="完成" type="object" class="btn-primary"
                                invisible="state not in ('draft', 'confirmed')"/>
                        <button name="action_cancel" string="取消" type="object"
                                invisible="state in ('cancel', 'legacy_confirmed')"/>
                        <field name="validation_status" invisible="1"/>
                        <field name="can_review" invisible="1"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirmed,done,legacy_confirmed,cancel"/>
                    </header>
                    <sheet>
                        <notebook>
                            <page string="办理类型">
                                <group>
                                    <field name="name" readonly="1"/>
                                    <field name="loan_flow_label" readonly="1"/>
                                    <field name="source_origin" invisible="1"/>
                                    <field name="business_category_id" readonly="state == 'legacy_confirmed'"/>
                                    <field name="loan_type" readonly="state == 'legacy_confirmed'"/>
                                    <field name="direction" readonly="state == 'legacy_confirmed'"/>
                                    <field name="document_no" readonly="state == 'legacy_confirmed'"/>
                                </group>
                            </page>
                            <page string="项目与借款方">
                                <group>
                                    <field name="project_id" readonly="state == 'legacy_confirmed'"/>
                                    <field name="operation_strategy" readonly="1"/>
                                    <field name="partner_id"/>
                                </group>
                            </page>
                            <page string="项目借公司款">
                                <group>
                                    <field name="document_date" required="1" readonly="state == 'legacy_confirmed'"/>
                                    <field name="due_date" readonly="state == 'legacy_confirmed'"/>
                                    <field name="amount" string="借款金额" readonly="state == 'legacy_confirmed'"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="purpose" readonly="state == 'legacy_confirmed'"/>
                                    <field name="rate_label" readonly="state == 'legacy_confirmed'"/>
                                    <field name="extra_ref" readonly="state == 'legacy_confirmed'"/>
                                    <field name="extra_label" readonly="state == 'legacy_confirmed'"/>
                                </group>
                            </page>
                            <page string="申请信息">
                                <group>
                                    <field name="financing_loan_request_department"/>
                                    <field name="financing_loan_request_time"/>
                                    <field name="financing_loan_budget_included"/>
                                    <field name="financing_loan_request_amount"/>
                                    <field name="financing_loan_actual_loan_amount"/>
                                    <field name="financing_loan_approved_amount"/>
                                    <field name="financing_loan_fund_usage_plan"/>
                                    <field name="financing_loan_bank_name"/>
                                    <field name="financing_loan_borrow_account"/>
                                    <field name="financing_loan_expected_return_time"/>
                                    <field name="financing_loan_loan_type_display"/>
                                </group>
                            </page>
                            <page string="办理说明">
                                <group>
                                    <field name="note"/>
                                    <field name="attachment_ids" widget="many2many_binary"/>
                                </group>
                            </page>
                            <page string="迁移来源" invisible="source_origin != 'legacy'">
                                <group>
                                    <field name="creator_name" readonly="1"/>
                                    <field name="created_time" readonly="1"/>
                                    <field name="active"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sc_financing_loan" model="ir.actions.act_window">
            <field name="name">融资借款</field>
            <field name="res_model">sc.financing.loan</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_sc_financing_loan_search"/>
            <field name="context">{'search_default_group_project': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_business_initiator')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
        </record>

        <menuitem id="menu_sc_financing_loan"
                  name="融资借款"
                  parent="smart_construction_core.menu_sc_finance_center"
                  action="action_sc_financing_loan"
                  sequence="38"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>
    </data>
</odoo>
