<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_payment_execution_search" model="ir.ui.view">
            <field name="name">sc.payment.execution.search</field>
            <field name="model">sc.payment.execution</field>
            <field name="arch" type="xml">
                <search string="付款登记办理">
                    <field name="name"/>
                    <field name="document_no"/>
                    <field name="project_id"/>
                    <field name="operation_strategy"/>
                    <field name="partner_id"/>
                    <field name="payment_request_partner_id"/>
                    <field name="actual_payee_partner_id"/>
                    <field name="payment_request_partner_relation"/>
                    <field name="company_contractor_responsibility_state" optional="show"/>
                    <field name="company_contractor_arrival_unprocessed_amount" optional="hide" sum="到款可处理余额合计"/>
                    <field name="company_contractor_arrival_over_processed_amount" optional="show" sum="到款超处理金额合计"/>
                    <field name="company_contractor_self_funding_balance" optional="hide" sum="自筹未退余额合计"/>
                    <field name="contract_id"/>
                    <field name="payment_family"/>
                    <field name="payment_method"/>
                    <field name="push_result"/>
                    <field name="kingdee_document_no"/>
                    <filter string="付款申请残余" name="source_kind_outflow_request" domain="[('source_kind', '=', 'outflow_request')]"/>
                    <filter string="实付残余" name="source_kind_actual_outflow" domain="[('source_kind', '=', 'actual_outflow')]"/>
                    <filter string="已确认" name="state_confirmed" domain="[('state', 'in', ['confirmed', 'legacy_confirmed'])]"/>
                    <filter string="已付款" name="state_paid" domain="[('state', '=', 'paid')]"/>
                    <filter string="公司直营" name="operation_direct" domain="[('operation_strategy', '=', 'direct')]"/>
                    <filter string="联营项目" name="operation_joint" domain="[('operation_strategy', '=', 'joint')]"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按经营策略" name="group_operation_strategy" context="{'group_by': 'operation_strategy'}"/>
                    <filter string="按单位" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="按申请/收款方关系" name="group_payment_request_partner_relation" context="{'group_by': 'payment_request_partner_relation'}"/>
                    <separator/>
                    <filter string="按推送结果" name="group_push_result" context="{'group_by': 'push_result'}"/>
                    <filter string="按业务类型" name="group_source_kind" context="{'group_by': 'source_kind'}"/>
                    <filter string="按付款族" name="group_payment_family" context="{'group_by': 'payment_family'}"/>
                    <filter string="按付款方式" name="group_payment_method" context="{'group_by': 'payment_method'}"/>
                    <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="按日期" name="group_date" context="{'group_by': 'date_payment'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_payment_execution_tree" model="ir.ui.view">
            <field name="name">sc.payment.execution.tree</field>
            <field name="model">sc.payment.execution</field>
            <field name="arch" type="xml">
                <tree string="付款登记办理">
                    <field name="name"/>
                    <field name="execution_flow_label"/>
                    <field name="business_category_id" optional="show"/>
                    <field name="date_payment"/>
                    <field name="project_id"/>
                    <field name="operation_strategy"/>
                    <field name="partner_id"/>
                    <field name="payment_request_partner_id" optional="hide"/>
                    <field name="actual_payee_partner_id" optional="hide"/>
                    <field name="payment_request_partner_relation" optional="show"/>
                    <field name="contract_id"/>
                    <field name="source_kind" optional="hide"/>
                    <field name="document_no"/>
                    <field name="payment_family"/>
                    <field name="payment_method"/>
                    <field name="push_result" optional="hide"/>
                    <field name="kingdee_document_no" optional="hide"/>
                    <field name="bank_account"/>
                    <field name="payment_account_name"/>
                    <field name="payment_account_no"/>
                    <field name="payment_bank_name"/>
                    <field name="receipt_account_name"/>
                    <field name="receipt_account_no"/>
                    <field name="receipt_bank_name"/>
                    <field name="handler_name"/>
                    <field name="planned_amount" sum="申请/计划金额"/>
                    <field name="paid_amount" sum="实付金额"/>
                    <field name="invoice_amount" sum="发票金额"/>
                    <field name="creator_name" optional="show"/>
                    <field name="created_time" optional="show"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_payment_execution_form" model="ir.ui.view">
            <field name="name">sc.payment.execution.form</field>
            <field name="model">sc.payment.execution</field>
            <field name="arch" type="xml">
                <form string="付款登记办理">
                    <header>
                        <button name="action_confirm" string="提交审批" type="object" class="btn-primary"
                                invisible="state != 'draft' or validation_status in ('waiting', 'pending', 'validated')"/>
                        <button name="validate_tier" string="审批通过" type="object" class="btn-primary"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="reject_tier" string="审批驳回" type="object"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="action_paid" string="已付款" type="object" class="btn-primary"
                                invisible="state not in ('draft', 'confirmed')"/>
                        <button name="action_cancel" string="取消" type="object"
                                invisible="state not in ('draft', 'confirmed')"/>
                        <button name="action_cancel" string="撤销付款" type="object" class="btn-secondary"
                                invisible="state != 'paid'"/>
                        <field name="validation_status" invisible="1"/>
                        <field name="can_review" invisible="1"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirmed,paid,legacy_confirmed,cancel"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="办理类型">
                                <field name="business_category_id" options="{'no_create': True}"/>
                                <field name="execution_flow_label" readonly="1"/>
                                <field name="state" readonly="1"/>
                                <field name="name" readonly="1"/>
                            </group>
                            <group string="付款依据">
                                <field name="payment_request_id" domain="[('type', '=', 'pay'), ('project_id', '=', project_id)]" readonly="state == 'legacy_confirmed'"/>
                                <field name="project_id" readonly="state == 'legacy_confirmed'"/>
                                <field name="operation_strategy" readonly="1"/>
                                <field name="partner_id" readonly="state == 'legacy_confirmed'"/>
                                <field name="payment_request_partner_id" readonly="1"/>
                                <field name="actual_payee_partner_id" readonly="1"/>
                                <field name="payment_request_partner_relation" readonly="1"/>
                                <field name="contract_id" readonly="state == 'legacy_confirmed'"/>
                            </group>
                        </group>
                        <group>
                            <group string="付款金额">
                                <field name="date_payment" readonly="state == 'legacy_confirmed'"/>
                                <field name="paid_amount" readonly="state == 'legacy_confirmed'"/>
                                <field name="planned_amount" readonly="state == 'legacy_confirmed'"/>
                                <field name="invoice_amount" readonly="state == 'legacy_confirmed'"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group string="办理说明">
                                <field name="payment_method" readonly="state == 'legacy_confirmed'"/>
                                <field name="handler_name" readonly="state == 'legacy_confirmed'"/>
                                <field name="document_no" readonly="state == 'legacy_confirmed'"/>
                                <field name="note" readonly="state == 'legacy_confirmed'"/>
                            </group>
                        </group>
                        <group>
                            <group string="收款账户">
                                <field name="receipt_account_name" readonly="state == 'legacy_confirmed'"/>
                                <field name="receipt_bank_name" readonly="state == 'legacy_confirmed'"/>
                                <field name="receipt_account_no" readonly="state == 'legacy_confirmed'"/>
                            </group>
                            <group string="付款账户">
                                <field name="payment_account_name" readonly="state == 'legacy_confirmed'"/>
                                <field name="payment_bank_name" readonly="state == 'legacy_confirmed'"/>
                                <field name="payment_account_no" readonly="state == 'legacy_confirmed'"/>
                                <field name="bank_account" readonly="state == 'legacy_confirmed'"/>
                            </group>
                        </group>
                        <group string="附件">
                            <field name="attachment_ids" widget="many2many_binary" readonly="state == 'legacy_confirmed'"/>
                        </group>
                        <group string="公司-承包人资金责任">
                            <field name="company_contractor_responsibility_summary_id" invisible="1"/>
                            <field name="company_contractor_responsibility_state" readonly="1"/>
                            <field name="company_contractor_arrival_unprocessed_amount" readonly="1"/>
                            <field name="company_contractor_arrival_over_processed_amount" readonly="1"/>
                            <field name="company_contractor_self_funding_balance" readonly="1"/>
                            <field name="company_contractor_responsibility_notice" readonly="1" nolabel="1"/>
                            <button name="action_view_company_contractor_responsibility_summary"
                                    type="object"
                                    string="查看责任余额"
                                    class="btn-secondary"
                                    invisible="not company_contractor_responsibility_summary_id"/>
                        </group>
                        <group string="来源与系统追溯" invisible="state != 'legacy_confirmed'">
                            <field name="payment_family" readonly="1"/>
                            <field name="source_kind" readonly="1"/>
                            <field name="push_result" readonly="1"/>
                            <field name="kingdee_document_no" readonly="1"/>
                            <field name="active" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sc_payment_execution" model="ir.actions.act_window">
            <field name="name">付款执行</field>
            <field name="res_model">sc.payment.execution</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_sc_payment_execution_search"/>
            <field name="context">{'search_default_group_project': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_business_initiator')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
        </record>

        <menuitem id="menu_sc_payment_execution"
                  name="付款执行"
                  parent="smart_construction_core.menu_sc_finance_center"
                  action="action_sc_payment_execution"
                  sequence="36"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>
    </data>
</odoo>
