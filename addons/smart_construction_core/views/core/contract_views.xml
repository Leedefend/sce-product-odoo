                            <group>
                                <field name="note" />
                                <field name="attachment_ids" widget="many2many_binary" />
                            </group>
                        </page>
                        <page string="审批信息">
                            <field name="approval_info" />
                            <field name="attachment_text" string="平台附件文本" />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>
    <record id="view_construction_contract_search" model="ir.ui.view">
        <field name="name">construction.contract.search</field>
        <field name="model">construction.contract</field>
        <field name="arch" type="xml">
            <search string="项目合同">
                <field name="name" />
                <field name="subject" />
                <field name="project_id" />
                <field name="operation_strategy" />
                <field name="partner_id" />
                <field name="category_id" />
                <field name="contract_type_id" />
