<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sc_fund_account_search" model="ir.ui.view">
        <field name="name">sc.fund.account.search</field>
        <field name="model">sc.fund.account</field>
        <field name="arch" type="xml">
            <search string="资金账户">
                <field name="name"/>
                <field name="account_no"/>
                <field name="bank_name"/>
                <field name="project_id"/>
                <field name="operation_strategy"/>
                <field name="account_type"/>
                <filter string="启用" name="state_active" domain="[('state', '=', 'active')]"/>
                <filter string="默认账户" name="is_default" domain="[('is_default', '=', True)]"/>
                <filter string="历史迁移" name="source_legacy" domain="[('source_origin', '=', 'legacy')]"/>
                <filter string="公司直营" name="operation_direct" domain="[('operation_strategy', '=', 'direct')]"/>
                <filter string="联营项目" name="operation_joint" domain="[('operation_strategy', '=', 'joint')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按经营策略" name="group_operation_strategy" context="{'group_by': 'operation_strategy'}"/>
                <filter string="按账户类型" name="group_account_type" context="{'group_by': 'account_type'}"/>
                <filter string="按开户行" name="group_bank" context="{'group_by': 'bank_name'}"/>
                <filter string="按录入日期" name="group_create_date" context="{'group_by': 'create_date'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_fund_account_tree" model="ir.ui.view">
        <field name="name">sc.fund.account.tree</field>
        <field name="model">sc.fund.account</field>
        <field name="arch" type="xml">
            <tree string="资金账户" default_order="sequence,account_type,name,id">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="operation_strategy"/>
                <field name="account_type"/>
                <field name="bank_name"/>
                <field name="account_no"/>
                <field name="opening_balance" sum="期初余额"/>
                <field name="current_account_balance" sum="当前账面余额"/>
                <field name="current_bank_balance" sum="当前银行余额"/>
                <field name="balance_as_of_date"/>
                <field name="current_balance_source"/>
                <field name="is_default"/>
                <field name="fixed_account"/>
                <field name="state"/>
                <field name="source_origin"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_fund_account_form" model="ir.ui.view">
        <field name="name">sc.fund.account.form</field>
        <field name="model">sc.fund.account</field>
        <field name="arch" type="xml">
            <form string="资金账户">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="active,inactive"/>
                </header>
                <sheet>
                    <group>
                        <group string="账户信息">
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="account_no"/>
                            <field name="account_type"/>
                            <field name="bank_name"/>
                            <field name="project_id"/>
                            <field name="operation_strategy" readonly="1"/>
                            <field name="source_origin" readonly="1"/>
                            <field name="company_id"/>
                        </group>
                        <group string="资金信息">
                            <field name="currency_id" invisible="1"/>
                            <field name="opening_balance"/>
                            <field name="current_account_balance" readonly="1"/>
                            <field name="current_bank_balance" readonly="1"/>
                            <field name="balance_as_of_date" readonly="1"/>
                            <field name="current_balance_source" readonly="1"/>
                            <field name="balance_source_operation_id" readonly="1"/>
                            <field name="is_default"/>
                            <field name="fixed_account"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="备注">
                            <field name="note"/>
                        </page>
                        <page string="历史来源" groups="smart_construction_core.group_sc_cap_config_admin">
                            <group>
                                <field name="source_origin"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_fund_account" model="ir.actions.act_window">
        <field name="name">账户管理</field>
        <field name="res_model">sc.fund.account</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_fund_account_search"/>
        <field name="context">{'search_default_state_active': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
    </record>
</odoo>
