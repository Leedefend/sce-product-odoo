<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sc_fund_account_operation_search" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.search</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <search string="账户资金办理">
                <field name="name"/>
                <field name="operation_date"/>
                <field name="source_account_id"/>
                <field name="target_account_id"/>
                <field name="project_id"/>
                <field name="business_category_id"/>
                <field name="operation_strategy"/>
                <filter string="资金划拨" name="type_transfer_out" domain="[('operation_type', '=', 'transfer_out')]"/>
                <filter string="账户间资金往来" name="type_transfer_between" domain="[('operation_type', '=', 'transfer_between')]"/>
                <filter string="余额调整" name="type_balance_adjustment" domain="[('operation_type', '=', 'balance_adjustment')]"/>
                <filter string="资金日报表" name="type_fund_daily_report" domain="[('operation_type', '=', 'fund_daily_report')]"/>
                <filter string="已完成" name="state_done" domain="[('state', '=', 'done')]"/>
                <filter string="公司直营" name="operation_direct" domain="[('operation_strategy', '=', 'direct')]"/>
                <filter string="联营项目" name="operation_joint" domain="[('operation_strategy', '=', 'joint')]"/>
                <filter string="按业务类型" name="group_operation_type" context="{'group_by': 'operation_type'}"/>
                <filter string="按业务分类" name="group_business_category" context="{'group_by': 'business_category_id'}"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按经营策略" name="group_operation_strategy" context="{'group_by': 'operation_strategy'}"/>
                <filter string="按日期" name="group_operation_date" context="{'group_by': 'operation_date'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_fund_account_operation_tree" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.tree</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <tree string="账户资金办理" default_order="operation_date desc,id desc">
                <field name="name"/>
                <field name="fund_flow_label"/>
                <field name="operation_date"/>
                <field name="project_id"/>
                <field name="operation_strategy"/>
                <field name="source_account_id"/>
                <field name="source_project_id" optional="show"/>
                <field name="target_account_id"/>
                <field name="target_project_id" optional="show"/>
                <field name="amount" string="调拨金额" sum="金额合计"/>
                <field name="operation_reason"/>
                <field name="business_category_id" optional="show"/>
                <field name="operation_type" optional="hide"/>
                <field name="fund_account_id" optional="hide"/>
                <field name="daily_income" sum="收入合计"/>
                <field name="daily_expense" sum="支出合计"/>
                <field name="account_balance"/>
                <field name="bank_balance"/>
                <field name="before_balance"/>
                <field name="after_balance"/>
                <field name="creator_name" optional="show"/>
                <field name="created_time" optional="show"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_fund_account_operation_user_tree" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.user.tree</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <tree string="账户资金办理" default_order="operation_date desc,id desc">
                <field name="name" string="单据号"/>
                <field name="fund_flow_label"/>
                <field name="operation_date"/>
                <field name="project_id"/>
                <field name="operation_strategy"/>
                <field name="source_account_id"/>
                <field name="source_project_id" optional="show"/>
                <field name="target_account_id"/>
                <field name="target_project_id" optional="show"/>
                <field name="amount" string="办理金额" sum="金额合计"/>
                <field name="operation_reason"/>
                <field name="business_category_id" optional="show"/>
                <field name="operation_type" optional="hide"/>
                <field name="fund_account_id" optional="hide"/>
                <field name="daily_income" sum="收入合计"/>
                <field name="daily_expense" sum="支出合计"/>
                <field name="account_balance"/>
                <field name="bank_balance"/>
                <field name="before_balance"/>
                <field name="after_balance"/>
                <field name="creator_name" optional="show"/>
                <field name="created_time" optional="show"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_fund_account_operation_form" model="ir.ui.view">
        <field name="name">sc.fund.account.operation.form</field>
        <field name="model">sc.fund.account.operation</field>
        <field name="arch" type="xml">
            <form string="账户资金办理">
                <header>
                    <button name="action_confirm" string="确认" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_done" string="完成" type="object" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft" string="重置草稿" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <notebook>
                        <page string="办理类型">
                            <group>
                                <group>
                                    <field name="name" readonly="1"/>
                                    <field name="fund_flow_label" readonly="1"/>
                                    <field name="operation_type"/>
                                    <field name="business_category_id" options="{'no_create': True}"/>
                                </group>
                                <group>
                                    <field name="state" readonly="1"/>
                                    <field name="operation_date" required="1"/>
                                    <field name="company_id"/>
                                    <field name="active"/>
                                    <field name="currency_id" invisible="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="项目与账户">
                            <group>
                                <group>
                                    <field name="project_id"/>
                                    <field name="operation_strategy" readonly="1"/>
                                    <field name="fund_account_id"
                                           invisible="operation_type not in ('balance_adjustment', 'fund_daily_report')"/>
                                </group>
                                <group>
                                    <field name="source_account_id"
                                           invisible="operation_type in ('balance_adjustment', 'fund_daily_report')"/>
                                    <field name="source_project_id"
                                           readonly="1"
                                           invisible="operation_type in ('balance_adjustment', 'fund_daily_report')"/>
                                    <field name="target_account_id"
                                           invisible="operation_type in ('balance_adjustment', 'fund_daily_report')"/>
                                    <field name="target_project_id"
                                           readonly="1"
                                           invisible="operation_type in ('balance_adjustment', 'fund_daily_report')"/>
                                </group>
                            </group>
                        </page>
                        <page string="调拨金额" invisible="operation_type in ('balance_adjustment', 'fund_daily_report')">
                            <group>
                                <field name="amount" string="办理金额"/>
                            </group>
                        </page>
                        <page string="资金日报" invisible="operation_type != 'fund_daily_report'">
                            <group>
                                <field name="daily_income"/>
                                <field name="daily_expense"/>
                                <field name="account_balance"/>
                                <field name="bank_balance"/>
                            </group>
                        </page>
                        <page string="余额调整" invisible="operation_type != 'balance_adjustment'">
                            <group>
                                <field name="before_balance"/>
                                <field name="after_balance"/>
                            </group>
                        </page>
                        <page string="办理说明">
                            <group>
                                <field name="operation_reason"/>
                                <field name="note"/>
                                <field name="attachment_ids" widget="many2many_binary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_sc_fund_transfer_out" model="ir.actions.act_window">
        <field name="name">资金划拨</field>
        <field name="res_model">sc.fund.account.operation</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_sc_fund_account_operation_tree"/>
        <field name="views" eval="[(ref('view_sc_fund_account_operation_tree'), 'tree'), (ref('view_sc_fund_account_operation_form'), 'form')]"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_sc_fund_account_operation_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_sc_fund_account_operation_form')})
        ]"/>
        <field name="search_view_id" ref="view_sc_fund_account_operation_search"/>
        <field name="domain">[('operation_type', '=', 'transfer_out'), ('business_category_id.code', '=', 'finance.fund.transfer')]</field>
        <field name="context">{'default_operation_type': 'transfer_out', 'default_business_category_code': 'finance.fund.transfer', 'search_default_type_transfer_out': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
    </record>

    <record id="action_sc_fund_transfer_between" model="ir.actions.act_window">
        <field name="name">资金调拨</field>
        <field name="res_model">sc.fund.account.operation</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_sc_fund_account_operation_tree"/>
        <field name="views" eval="[(ref('view_sc_fund_account_operation_tree'), 'tree'), (ref('view_sc_fund_account_operation_form'), 'form')]"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_sc_fund_account_operation_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_sc_fund_account_operation_form')})
        ]"/>
        <field name="search_view_id" ref="view_sc_fund_account_operation_search"/>
        <field name="domain">[('operation_type', '=', 'transfer_between'), ('business_category_id.code', '=', 'finance.fund.transfer')]</field>
        <field name="context">{'default_operation_type': 'transfer_between', 'default_business_category_code': 'finance.fund.transfer', 'search_default_type_transfer_between': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
    </record>

    <record id="action_sc_fund_balance_adjustment" model="ir.actions.act_window">
        <field name="name">余额调整</field>
        <field name="res_model">sc.fund.account.operation</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_sc_fund_account_operation_tree"/>
        <field name="views" eval="[(ref('view_sc_fund_account_operation_tree'), 'tree'), (ref('view_sc_fund_account_operation_form'), 'form')]"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_sc_fund_account_operation_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_sc_fund_account_operation_form')})
        ]"/>
        <field name="search_view_id" ref="view_sc_fund_account_operation_search"/>
        <field name="domain">[('business_category_id.code', '=', 'finance.fund.balance_adjustment')]</field>
        <field name="context">{'default_operation_type': 'balance_adjustment', 'default_business_category_code': 'finance.fund.balance_adjustment', 'search_default_type_balance_adjustment': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
    </record>
</odoo>
