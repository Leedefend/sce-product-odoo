                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="管理要求">
                            <field name="management_note" nolabel="1"/>
                        </page>
                        <page string="备注">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
