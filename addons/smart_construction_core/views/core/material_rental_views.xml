<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_sc_material_rental_plan" model="ir.actions.act_window">
        <field name="name">租赁计划</field>
        <field name="res_model">sc.material.rental.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_material_read'),
            ref('smart_construction_core.group_sc_cap_material_user'),
            ref('smart_construction_core.group_sc_cap_material_manager')
        ])]"/>
    </record>

    <record id="action_sc_material_rental_order" model="ir.actions.act_window">
        <field name="name">租赁单</field>
        <field name="res_model">sc.material.rental.order</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_material_read'),
            ref('smart_construction_core.group_sc_cap_material_user'),
            ref('smart_construction_core.group_sc_cap_material_manager')
        ])]"/>
    </record>

    <record id="action_sc_material_rental_in_acceptance" model="ir.actions.act_window">
        <field name="name">租入</field>
        <field name="res_model">sc.material.rental.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('legacy_fact_type', '=', 'legacy_direct_lease_in')]</field>
        <field name="context">{'search_default_group_project': 1}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_material_read'),
            ref('smart_construction_core.group_sc_cap_material_user'),
            ref('smart_construction_core.group_sc_cap_material_manager')
        ])]"/>
    </record>

    <record id="action_sc_material_rental_return_acceptance" model="ir.actions.act_window">
        <field name="name">还租</field>
        <field name="res_model">sc.material.rental.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('legacy_fact_type', '=', 'legacy_direct_lease_return')]</field>
        <field name="context">{'search_default_group_project': 1}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_material_read'),
            ref('smart_construction_core.group_sc_cap_material_user'),
            ref('smart_construction_core.group_sc_cap_material_manager')
        ])]"/>
    </record>

    <record id="action_sc_material_rental_settlement" model="ir.actions.act_window">
        <field name="name">租赁结算</field>
        <field name="res_model">sc.material.rental.settlement</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_material_read'),
            ref('smart_construction_core.group_sc_cap_material_user'),
            ref('smart_construction_core.group_sc_cap_material_manager')
        ])]"/>
    </record>

    <record id="view_sc_material_rental_plan_tree" model="ir.ui.view">
        <field name="name">sc.material.rental.plan.tree</field>
        <field name="model">sc.material.rental.plan</field>
        <field name="arch" type="xml">
            <tree string="周转材料租赁计划" default_order="plan_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="plan_date"/>
                <field name="planned_start"/>
                <field name="planned_end"/>
                <field name="rent_purpose"/>
                <field name="supplier_id"/>
                <field name="contract_id"/>
                <field name="estimated_amount" sum="预计租赁金额合计"/>
                <field name="currency_id" invisible="1"/>
                <field name="owner_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_material_rental_plan_form" model="ir.ui.view">
        <field name="name">sc.material.rental.plan.form</field>
        <field name="model">sc.material.rental.plan</field>
        <field name="arch" type="xml">
            <form string="周转材料租赁计划">
                <header>
                    <button name="action_submit" string="提交" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="确认" type="object" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="退回草稿" type="object" invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('approved', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="plan_date"/>
                            <field name="planned_start"/>
                            <field name="planned_end"/>
                            <field name="rent_purpose"/>
                        </group>
                        <group>
                            <field name="supplier_id"/>
                            <field name="contract_id"/>
                            <field name="owner_id"/>
                            <field name="estimated_amount" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="计划明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="material_catalog_id" required="1"/>
                                    <field name="product_id" invisible="1"/>
                                    <field name="material_name"/>
                                    <field name="material_spec"/>
                                    <field name="unit_name"/>
                                    <field name="planned_qty"/>
                                    <field name="planned_days"/>
                                    <field name="daily_price"/>
                                    <field name="estimated_amount"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                        <page string="备注">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_material_rental_plan_search" model="ir.ui.view">
        <field name="name">sc.material.rental.plan.search</field>
        <field name="model">sc.material.rental.plan</field>
        <field name="arch" type="xml">
            <search string="周转材料租赁计划">
                <field name="name"/>
                <field name="project_id"/>
                <field name="supplier_id"/>
                <field name="contract_id"/>
                <field name="rent_purpose"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按供应商" name="group_supplier" context="{'group_by': 'supplier_id'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_material_rental_order_tree" model="ir.ui.view">
        <field name="name">sc.material.rental.order.tree</field>
        <field name="model">sc.material.rental.order</field>
        <field name="arch" type="xml">
            <tree string="周转材料租赁单" default_order="rental_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="rental_date"/>
                <field name="planned_return_date"/>
                <field name="plan_id"/>
                <field name="contract_id"/>
                <field name="supplier_id"/>
                <field name="amount_total" sum="租赁金额合计"/>
                <field name="currency_id" invisible="1"/>
                <field name="owner_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_material_rental_order_form" model="ir.ui.view">
        <field name="name">sc.material.rental.order.form</field>
        <field name="model">sc.material.rental.order</field>
        <field name="arch" type="xml">
            <form string="周转材料租赁单">
                <header>
                    <button name="action_activate" string="确认租赁" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_return" string="确认退还" type="object" class="btn-primary" invisible="state != 'active'"/>
                    <button name="action_settle" string="完成结算" type="object" class="btn-primary" invisible="state != 'returned'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('settled', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,returned,settled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="plan_id"/>
                            <field name="rental_date"/>
                            <field name="planned_return_date"/>
                        </group>
                        <group>
                            <field name="supplier_id"/>
                            <field name="contract_id"/>
                            <field name="owner_id"/>
                            <field name="amount_total" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="租赁明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="material_catalog_id" required="1"/>
                                    <field name="product_id" invisible="1"/>
                                    <field name="material_name"/>
                                    <field name="material_spec"/>
                                    <field name="unit_name"/>
                                    <field name="qty"/>
                                    <field name="rental_days"/>
                                    <field name="daily_price"/>
                                    <field name="amount_total"/>
                                    <field name="returned_qty"/>
                                    <field name="damage_qty"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                        <page string="备注">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_material_rental_order_search" model="ir.ui.view">
        <field name="name">sc.material.rental.order.search</field>
        <field name="model">sc.material.rental.order</field>
        <field name="arch" type="xml">
            <search string="周转材料租赁单">
                <field name="name"/>
                <field name="project_id"/>
                <field name="supplier_id"/>
                <field name="contract_id"/>
                <field name="plan_id"/>
                <field name="rental_date"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按供应商" name="group_supplier" context="{'group_by': 'supplier_id'}"/>
                <filter string="按日期" name="group_rental_date" context="{'group_by': 'rental_date'}"/>
                <filter string="按业务分类" name="group_legacy_acceptance_label" context="{'group_by': 'legacy_acceptance_label'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_material_rental_settlement_tree" model="ir.ui.view">
        <field name="name">sc.material.rental.settlement.tree</field>
        <field name="model">sc.material.rental.settlement</field>
