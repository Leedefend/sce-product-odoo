                            <field name="contract_id"/>
                            <field name="owner_id"/>
                            <field name="rent_amount" readonly="1"/>
                            <field name="damage_amount" readonly="1"/>
                            <field name="amount_total" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="结算明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="material_catalog_id" required="1"/>
                                    <field name="product_id" invisible="1"/>
                                    <field name="material_name"/>
                                    <field name="material_spec"/>
                                    <field name="unit_name"/>
                                    <field name="qty"/>
                                    <field name="rental_days"/>
                                    <field name="daily_price"/>
                                    <field name="rent_amount"/>
                                    <field name="damage_amount"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                        <page string="备注">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
