                <field name="rental_order_id"/>
                <field name="contract_id"/>
                <field name="supplier_id"/>
                <field name="payment_request_id"/>
                <field name="rent_amount" sum="租金金额合计"/>
                <field name="damage_amount" sum="赔偿金额合计"/>
                <field name="amount_total" sum="结算金额合计"/>
                <field name="currency_id" invisible="1"/>
                <field name="owner_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

