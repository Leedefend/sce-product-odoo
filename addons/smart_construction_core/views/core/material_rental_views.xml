                    <button name="action_paid" string="确认支付" type="object" class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('paid', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,confirmed,paid"/>
                </header>
                <sheet>
