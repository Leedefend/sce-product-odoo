<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_sc_check_standard" model="ir.actions.act_window">
        <field name="name">检查标准</field>
        <field name="res_model">sc.check.standard</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_sc_check_standard_item" model="ir.actions.act_window">
        <field name="name">检查项维护</field>
        <field name="res_model">sc.check.standard.item</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_sc_quality_issue" model="ir.actions.act_window">
        <field name="name">质量问题闭环</field>
        <field name="res_model">sc.quality.issue</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_sc_quality_rectification" model="ir.actions.act_window">
        <field name="name">质量整改执行</field>
        <field name="res_model">sc.quality.rectification</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_sc_quality_recheck" model="ir.actions.act_window">
        <field name="name">质量复验</field>
        <field name="res_model">sc.quality.recheck</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_sc_site_photo_batch" model="ir.actions.act_window">
        <field name="name">现场照片批次</field>
        <field name="res_model">sc.site.photo.batch</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="view_sc_check_standard_tree" model="ir.ui.view">
        <field name="name">sc.check.standard.tree</field>
        <field name="model">sc.check.standard</field>
        <field name="arch" type="xml">
            <tree string="检查标准">
                <field name="name"/>
                <field name="standard_type"/>
                <field name="scope"/>
                <field name="import_source"/>
                <field name="company_id"/>
                <field name="project_id"/>
                <field name="default_rechecker_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_check_standard_form" model="ir.ui.view">
        <field name="name">sc.check.standard.form</field>
        <field name="model">sc.check.standard</field>
        <field name="arch" type="xml">
            <form string="检查标准">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="standard_type"/>
                        <field name="scope"/>
                        <field name="company_id"/>
                        <field name="project_id"/>
                        <field name="parent_id"/>
                        <field name="default_rechecker_id"/>
                        <field name="cc_user_ids" widget="many2many_tags"/>
                        <field name="import_source"/>
                        <field name="effective_from"/>
                        <field name="effective_to"/>
                        <field name="applies_building_room"/>
                        <field name="applies_road_coordinate"/>
                        <field name="active"/>
                    </group>
                    <group string="来源追溯">
                    </group>
                    <field name="item_ids">
                        <tree editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="control_type"/>
                            <field name="requirement"/>
                            <field name="bottom_line"/>
                            <field name="default_pass"/>
                            <field name="photo_required"/>
                            <field name="acceptance_flow"/>
                            <field name="score_weight"/>
                            <field name="tag"/>
                        </tree>
                    </field>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_check_standard_item_tree" model="ir.ui.view">
        <field name="name">sc.check.standard.item.tree</field>
        <field name="model">sc.check.standard.item</field>
        <field name="arch" type="xml">
            <tree string="检查项" default_order="standard_id, sequence, id">
                <field name="sequence" widget="handle"/>
                <field name="standard_id"/>
                <field name="name"/>
                <field name="requirement"/>
                <field name="control_type"/>
                <field name="bottom_line"/>
                <field name="default_pass"/>
                <field name="photo_required"/>
                <field name="acceptance_flow"/>
                <field name="score_weight"/>
                <field name="tag"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_check_standard_item_form" model="ir.ui.view">
        <field name="name">sc.check.standard.item.form</field>
        <field name="model">sc.check.standard.item</field>
        <field name="arch" type="xml">
            <form string="检查项">
                <sheet>
                    <group>
                        <field name="standard_id"/>
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="requirement"/>
                        <field name="control_type"/>
                        <field name="bottom_line"/>
                        <field name="default_pass"/>
                        <field name="photo_required"/>
                        <field name="measurement_method"/>
                        <field name="acceptance_flow"/>
                        <field name="score_weight"/>
                        <field name="tag"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_check_standard_item_search" model="ir.ui.view">
        <field name="name">sc.check.standard.item.search</field>
        <field name="model">sc.check.standard.item</field>
        <field name="arch" type="xml">
            <search string="检查项">
                <field name="name"/>
                <field name="standard_id"/>
                <field name="tag"/>
                <field name="control_type"/>
                <filter string="拍照必填" name="photo_required" domain="[('photo_required', '=', True)]"/>
                <filter string="底线项" name="bottom_line" domain="[('bottom_line', '=', True)]"/>
                <filter string="按检查标准" name="group_standard" context="{'group_by': 'standard_id'}"/>
                <filter string="按控制类型" name="group_control_type" context="{'group_by': 'control_type'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_quality_issue_tree" model="ir.ui.view">
        <field name="name">sc.quality.issue.tree</field>
        <field name="model">sc.quality.issue</field>
        <field name="arch" type="xml">
            <tree string="质量问题" default_order="issue_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="issue_category"/>
                <field name="source_channel"/>
                <field name="issue_date"/>
                <field name="location"/>
                <field name="issue_level"/>
                <field name="responsible_party_id"/>
                <field name="rechecker_id"/>
                <field name="rectification_deadline"/>
                <field name="overdue_days"/>
                <field name="is_overdue"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_quality_issue_form" model="ir.ui.view">
        <field name="name">sc.quality.issue.form</field>
        <field name="model">sc.quality.issue</field>
        <field name="arch" type="xml">
            <form string="质量问题">
                <header>
                    <button name="action_submit" string="提交" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('closed', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,rectifying,rechecking,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="issue_category"/>
                            <field name="source_channel"/>
                            <field name="issue_level"/>
                            <field name="issue_date"/>
                        </group>
                        <group>
                            <field name="location"/>
                            <field name="coordinate"/>
                            <field name="responsible_party_id"/>
                            <field name="owner_id"/>
                            <field name="rechecker_id"/>
                            <field name="cc_user_ids" widget="many2many_tags"/>
                            <field name="rectification_deadline"/>
                            <field name="reminder_before_days"/>
                            <field name="closed_date" readonly="1"/>
                            <field name="overdue_days" readonly="1"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="问题描述">
                            <field name="description" nolabel="1"/>
                            <field name="voice_text" nolabel="1"/>
                        </page>
                        <page string="问题附件">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="检查照片">
                            <field name="photo_batch_ids"/>
                        </page>
                        <page string="检查信息">
                            <group>
                                <field name="standard_id"/>
                                <field name="standard_item_id"/>
                                <field name="building"/>
                                <field name="room"/>
                                <field name="coordinate"/>
                            </group>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_quality_rectification_tree" model="ir.ui.view">
        <field name="name">sc.quality.rectification.tree</field>
        <field name="model">sc.quality.rectification</field>
        <field name="arch" type="xml">
            <tree string="质量整改" default_order="rectification_date desc">
                <field name="issue_id"/>
                <field name="project_id"/>
                <field name="source_channel"/>
                <field name="issue_level"/>
                <field name="responsible_party_id"/>
                <field name="rectification_deadline"/>
                <field name="rectification_date"/>
                <field name="handler_id"/>
                <field name="issue_state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_quality_rectification_form" model="ir.ui.view">
        <field name="name">sc.quality.rectification.form</field>
        <field name="model">sc.quality.rectification</field>
        <field name="arch" type="xml">
            <form string="质量整改">
                <sheet>
                    <group>
                        <group>
                            <field name="issue_id"/>
                            <field name="project_id" readonly="1"/>
                            <field name="issue_level" readonly="1"/>
                            <field name="issue_state" readonly="1"/>
                        </group>
                        <group>
                            <field name="responsible_party_id" readonly="1"/>
                            <field name="rectification_deadline" readonly="1"/>
                            <field name="rectification_date"/>
                            <field name="source_channel"/>
                            <field name="handler_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="整改结果">
                            <field name="result" nolabel="1"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="照片批次">
                            <field name="photo_batch_ids"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_quality_rectification_search" model="ir.ui.view">
        <field name="name">sc.quality.rectification.search</field>
        <field name="model">sc.quality.rectification</field>
        <field name="arch" type="xml">
            <search string="质量整改">
                <field name="issue_id"/>
                <field name="project_id"/>
                <field name="handler_id"/>
                <filter string="待整改问题" name="pending_rectification" domain="[('issue_state', 'in', ['submitted', 'rectifying'])]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按整改人" name="group_handler" context="{'group_by': 'handler_id'}"/>
                <filter string="按问题状态" name="group_issue_state" context="{'group_by': 'issue_state'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_quality_recheck_tree" model="ir.ui.view">
        <field name="name">sc.quality.recheck.tree</field>
        <field name="model">sc.quality.recheck</field>
        <field name="arch" type="xml">
            <tree string="质量复验" default_order="recheck_date desc">
                <field name="issue_id"/>
                <field name="project_id"/>
                <field name="source_channel"/>
                <field name="issue_level"/>
                <field name="responsible_party_id"/>
                <field name="recheck_date"/>
                <field name="recheck_user_id"/>
                <field name="result"/>
                <field name="issue_state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_quality_recheck_form" model="ir.ui.view">
        <field name="name">sc.quality.recheck.form</field>
        <field name="model">sc.quality.recheck</field>
        <field name="arch" type="xml">
            <form string="质量复验">
                <sheet>
                    <group>
                        <group>
                            <field name="issue_id"/>
                            <field name="project_id" readonly="1"/>
                            <field name="issue_level" readonly="1"/>
                            <field name="issue_state" readonly="1"/>
                        </group>
                        <group>
                            <field name="responsible_party_id" readonly="1"/>
                            <field name="recheck_date"/>
                            <field name="source_channel"/>
                            <field name="recheck_user_id"/>
                            <field name="result"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="复验意见">
                            <field name="comment" nolabel="1"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="照片批次">
                            <field name="photo_batch_ids"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_quality_recheck_search" model="ir.ui.view">
        <field name="name">sc.quality.recheck.search</field>
        <field name="model">sc.quality.recheck</field>
        <field name="arch" type="xml">
            <search string="质量复验">
                <field name="issue_id"/>
                <field name="project_id"/>
                <field name="recheck_user_id"/>
                <filter string="待复验问题" name="pending_recheck" domain="[('issue_state', '=', 'rechecking')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按复验人" name="group_user" context="{'group_by': 'recheck_user_id'}"/>
                <filter string="按复验结果" name="group_result" context="{'group_by': 'result'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_site_photo_batch_tree" model="ir.ui.view">
        <field name="name">sc.site.photo.batch.tree</field>
        <field name="model">sc.site.photo.batch</field>
        <field name="arch" type="xml">
            <tree string="现场照片批次" default_order="batch_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="evidence_stage"/>
                <field name="source_channel"/>
                <field name="album_category"/>
                <field name="quality_issue_id"/>
                <field name="safety_issue_id"/>
                <field name="batch_date"/>
                <field name="owner_id"/>
                <field name="location"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_site_photo_batch_form" model="ir.ui.view">
        <field name="name">sc.site.photo.batch.form</field>
        <field name="model">sc.site.photo.batch</field>
        <field name="arch" type="xml">
            <form string="现场照片批次">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="evidence_stage"/>
                            <field name="source_channel"/>
                            <field name="album_category"/>
                            <field name="batch_date"/>
                            <field name="owner_id"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="quality_issue_id"/>
                            <field name="quality_rectification_id"/>
                            <field name="quality_recheck_id"/>
                            <field name="safety_issue_id"/>
                            <field name="safety_rectification_id"/>
                            <field name="safety_recheck_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="照片附件">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="说明">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_site_photo_batch_search" model="ir.ui.view">
        <field name="name">sc.site.photo.batch.search</field>
        <field name="model">sc.site.photo.batch</field>
        <field name="arch" type="xml">
            <search string="现场照片批次">
                <field name="name"/>
                <field name="project_id"/>
                <field name="owner_id"/>
                <field name="source_channel"/>
                <field name="album_category"/>
                <filter string="检查阶段" name="stage_check" domain="[('evidence_stage', '=', 'check')]"/>
                <filter string="整改阶段" name="stage_rectification" domain="[('evidence_stage', '=', 'rectification')]"/>
                <filter string="复验阶段" name="stage_recheck" domain="[('evidence_stage', '=', 'recheck')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按阶段" name="group_stage" context="{'group_by': 'evidence_stage'}"/>
                <filter string="按相册分类" name="group_album_category" context="{'group_by': 'album_category'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_quality_issue_search" model="ir.ui.view">
        <field name="name">sc.quality.issue.search</field>
        <field name="model">sc.quality.issue</field>
        <field name="arch" type="xml">
            <search string="质量问题">
                <field name="name"/>
                <field name="project_id"/>
                <field name="responsible_party_id"/>
                <field name="issue_category"/>
                <field name="source_channel"/>
                <filter string="未闭环" name="not_closed" domain="[('state', 'not in', ['closed', 'cancel'])]"/>
                <filter string="已逾期" name="overdue" domain="[('is_overdue', '=', True)]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按等级" name="group_level" context="{'group_by': 'issue_level'}"/>
                <filter string="按场景" name="group_issue_category" context="{'group_by': 'issue_category'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>
</odoo>
