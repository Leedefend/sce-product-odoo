<odoo>
    <record id="view_project_quick_create_wizard_form" model="ir.ui.view">
        <field name="name">project.quick.create.wizard.form</field>
        <field name="model">project.quick.create.wizard</field>
        <field name="arch" type="xml">
            <form string="快速创建项目">
                <group>
                    <field name="name" placeholder="请输入项目名称" required="1"/>
                    <field name="manager_id" required="1"/>
                    <field name="owner_id"/>
                </group>
                <footer>
                    <button name="action_quick_create" type="object" string="创建并进入项目驾驶舱" class="btn-primary"/>
                    <button string="取消" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_project_quick_create_wizard" model="ir.actions.act_window">
        <field name="name">快速创建项目</field>
        <field name="res_model">project.quick.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_project_quick_create_wizard_form"/>
        <field name="target">new</field>
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_project_manager'), ref('smart_construction_core.group_sc_super_admin')])]"/>
        <field name="context">{'default_manager_id': uid}</field>
    </record>
</odoo>
