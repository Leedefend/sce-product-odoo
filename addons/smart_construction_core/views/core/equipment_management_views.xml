                                    <field name="requested_qty"/>
                                    <field name="planned_hours"/>
                                    <field name="usage_location"/>
                                    <field name="operator_requirement"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="申请说明">
                            <field name="note" nolabel="1"/>
