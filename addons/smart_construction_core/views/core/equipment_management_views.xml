<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_sc_equipment_plan" model="ir.actions.act_window">
        <field name="name">设备计划</field>
        <field name="res_model">sc.equipment.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_sc_equipment_request" model="ir.actions.act_window">
        <field name="name">设备申请</field>
        <field name="res_model">sc.equipment.request</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_sc_equipment_usage" model="ir.actions.act_window">
        <field name="name">设备使用登记</field>
        <field name="res_model">sc.equipment.usage</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_sc_equipment_settlement" model="ir.actions.act_window">
        <field name="name">设备结算</field>
        <field name="res_model">sc.equipment.settlement</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_sc_equipment_price" model="ir.actions.act_window">
        <field name="name">设备价格库</field>
        <field name="res_model">sc.equipment.price</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <record id="view_sc_equipment_plan_tree" model="ir.ui.view">
        <field name="name">sc.equipment.plan.tree</field>
        <field name="model">sc.equipment.plan</field>
        <field name="arch" type="xml">
            <tree string="设备计划" default_order="plan_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="plan_date"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="usage_location"/>
                <field name="owner_id"/>
                <field name="supplier_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_equipment_plan_form" model="ir.ui.view">
        <field name="name">sc.equipment.plan.form</field>
        <field name="model">sc.equipment.plan</field>
        <field name="arch" type="xml">
            <form string="设备计划">
                <header>
                    <button name="action_submit" string="提交" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="确认计划" type="object" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="退回草稿" type="object" invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('approved', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="plan_date"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="usage_location"/>
                            <field name="owner_id"/>
                            <field name="supplier_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="计划明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="equipment_name"/>
                                    <field name="equipment_code"/>
                                    <field name="planned_qty"/>
                                    <field name="planned_hours"/>
                                    <field name="usage_location"/>
                                    <field name="operator_requirement"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="计划说明">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_equipment_plan_search" model="ir.ui.view">
        <field name="name">sc.equipment.plan.search</field>
        <field name="model">sc.equipment.plan</field>
        <field name="arch" type="xml">
            <search string="设备计划">
                <field name="name"/>
                <field name="project_id"/>
                <field name="plan_date"/>
                <field name="usage_location"/>
                <field name="owner_id"/>
                <field name="supplier_id"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="已提交" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="已确认" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按负责人" name="group_owner" context="{'group_by': 'owner_id'}"/>
                <filter string="按供应单位" name="group_supplier" context="{'group_by': 'supplier_id'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_equipment_request_tree" model="ir.ui.view">
        <field name="name">sc.equipment.request.tree</field>
        <field name="model">sc.equipment.request</field>
        <field name="arch" type="xml">
            <tree string="设备申请" default_order="request_date desc">
