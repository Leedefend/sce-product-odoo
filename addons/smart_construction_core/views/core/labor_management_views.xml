    <record id="view_sc_attendance_checkin_tree" model="ir.ui.view">
        <field name="name">sc.attendance.checkin.tree</field>
        <field name="model">sc.attendance.checkin</field>
        <field name="arch" type="xml">
            <tree string="考勤记录" default_order="attendance_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="attendance_date"/>
                <field name="labor_team"/>
                <field name="work_content"/>
                <field name="attendance_qty" sum="考勤人数合计"/>
                <field name="work_hours" sum="工时合计"/>
                <field name="contractor_id"/>
                <field name="recorder_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_labor_plan_tree" model="ir.ui.view">
        <field name="name">sc.labor.plan.tree</field>
        <field name="model">sc.labor.plan</field>
        <field name="arch" type="xml">
            <tree string="劳务计划" default_order="plan_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="plan_date"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="owner_id"/>
                <field name="contractor_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_labor_plan_form" model="ir.ui.view">
        <field name="name">sc.labor.plan.form</field>
        <field name="model">sc.labor.plan</field>
        <field name="arch" type="xml">
            <form string="劳务计划">
                <header>
                    <button name="action_submit" string="提交" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="确认计划" type="object" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="退回草稿" type="object" invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('approved', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="plan_date"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="owner_id"/>
                            <field name="contractor_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="计划明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="labor_team"/>
                                    <field name="work_content"/>
                                    <field name="planned_qty"/>
                                    <field name="planned_work_hours"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="计划说明">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_labor_plan_search" model="ir.ui.view">
        <field name="name">sc.labor.plan.search</field>
        <field name="model">sc.labor.plan</field>
        <field name="arch" type="xml">
            <search string="劳务计划">
                <field name="name"/>
                <field name="project_id"/>
                <field name="plan_date"/>
                <field name="owner_id"/>
                <field name="contractor_id"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="已提交" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="已确认" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按负责人" name="group_owner" context="{'group_by': 'owner_id'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

