<odoo>
    <data>
        <record id="view_sc_document_admin_document_search" model="ir.ui.view">
            <field name="name">sc.document.admin.document.search</field>
            <field name="model">sc.document.admin.document</field>
            <field name="arch" type="xml">
                <search string="资料证照办理">
                    <field name="name" />
                    <field name="document_no" />
                    <field name="fact_type" />
                    <field name="certificate_name" />
                    <field name="certificate_no" />
                    <field name="document_title" />
                    <field name="borrow_user_id" />
                    <filter string="公司资料存档" name="company_document_archive" domain="[('fact_type', '=', 'company_document_archive')]" />
                    <filter string="证照登记" name="certificate_registration" domain="[('fact_type', '=', 'certificate_registration')]" />
                    <filter string="借阅申请" name="document_borrow" domain="[('fact_type', '=', 'document_borrow')]" />
                    <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]" />
                    <filter string="办理中" name="in_progress" domain="[('state', '=', 'in_progress')]" />
                    <filter string="已完成" name="done" domain="[('state', '=', 'done')]" />
                    <group expand="0" string="分组">
                        <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}" />
                        <filter string="按业务日期" name="group_business_date" context="{'group_by': 'business_date'}" />
                        <filter string="按类型" name="group_type" context="{'group_by': 'fact_type'}" />
                        <filter string="按录入人" name="group_requester" context="{'group_by': 'requester_id'}" />
                        <filter string="按借阅人" name="group_borrow_user" context="{'group_by': 'borrow_user_id'}" />
                        <filter string="按状态" name="group_state" context="{'group_by': 'state'}" />
                    </group>
                </search>
            </field>
        </record>
        <record id="view_sc_document_admin_document_tree" model="ir.ui.view">
            <field name="name">sc.document.admin.document.tree</field>
            <field name="model">sc.document.admin.document</field>
            <field name="arch" type="xml">
                <tree string="资料证照办理" default_order="business_date desc, id desc">
                    <field name="document_no" />
                    <field name="business_date" />
                    <field name="fact_type" />
                    <field name="name" />
                    <field name="certificate_name" optional="show" />
                    <field name="certificate_no" optional="show" />
                    <field name="holder_name" optional="show" />
                    <field name="valid_until" optional="show" />
                    <field name="document_title" optional="show" />
                    <field name="borrow_user_id" optional="show" />
                    <field name="borrow_department_name" optional="hide" />
                    <field name="borrower_name" optional="hide" />
                    <field name="borrow_form" optional="hide" />
                    <field name="borrow_date" optional="show" />
                    <field name="return_request_date" optional="hide" />
                    <field name="returned_flag" optional="hide" />
                    <field name="expected_return_date" optional="show" />
                    <field name="actual_return_date" optional="hide" />
                    <field name="state" />
                </tree>
            </field>
        </record>
        <record id="view_sc_document_admin_document_form" model="ir.ui.view">
            <field name="name">sc.document.admin.document.form</field>
            <field name="model">sc.document.admin.document</field>
            <field name="arch" type="xml">
                <form string="资料证照办理">
                    <header>
                        <button name="action_submit" type="object" string="提交" class="btn-primary" invisible="state != 'draft'" />
                        <button name="action_done" type="object" string="完成" class="btn-primary" invisible="state not in ['draft', 'in_progress']" />
                        <button name="action_cancel" type="object" string="取消" invisible="state in ['done', 'cancel']" />
                        <button name="action_reset_draft" type="object" string="重置草稿" invisible="state == 'draft'" />
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done,cancel" />
                    </header>
                    <sheet>
                        <group>
                            <group string="申请信息">
                                <field name="document_no" />
                                <field name="name" />
                                <field name="fact_type" />
                                <field name="business_date" />
                                <field name="requester_id" />
                                <field name="department_id" />
                            </group>
                            <group string="公司资料存档" invisible="fact_type != 'company_document_archive'">
                                <field name="document_title" required="fact_type == 'company_document_archive'" />
                                <field name="holder_name" string="保管单位/部门" />
                            </group>
                            <group string="证照登记" invisible="fact_type != 'certificate_registration'">
                                <field name="certificate_name" required="fact_type == 'certificate_registration'" />
                                <field name="certificate_no" required="fact_type == 'certificate_registration'" />
                                <field name="holder_name" required="fact_type == 'certificate_registration'" />
                                <field name="issue_authority" />
                                <field name="issue_date" />
                                <field name="valid_until" />
                            </group>
                            <group string="借阅申请" invisible="fact_type != 'document_borrow'">
                                <field name="document_title" required="fact_type == 'document_borrow'" />
                                <field name="borrow_user_id" required="fact_type == 'document_borrow'" />
                                <field name="borrower_name" />
                                <field name="borrow_project_name" />
                                <field name="borrow_department_name" />
                                <field name="borrower_contact" />
                                <field name="borrow_form" />
                                <field name="borrow_date" required="fact_type == 'document_borrow'" />
                                <field name="application_date" />
                                <field name="responsible_person" />
                                <field name="expected_return_date" required="fact_type == 'document_borrow'" />
                                <field name="return_request_date" />
                                <field name="return_apply_time" />
                                <field name="returned_flag" />
                                <field name="return_confirm_time" />
                                <field name="actual_return_date" />
                                <field name="modifier_name" />
                                <field name="modified_at" />
                                <field name="modify_note" />
                                <field name="reviewer_name" />
                                <field name="review_time" />
                                <field name="review_opinion" />
                            </group>
                        </group>
                        <group>
                            <group string="办理">
                                <field name="handler_id" />
                                <field name="due_date" />
                                <field name="active" />
                            </group>
                            <group string="历史来源">
                            </group>
                        </group>
                        <notebook>
                            <page string="说明">
                                <field name="description" />
                                <field name="result_note" />
                            </page>
                            <page string="附件">
                                <field name="attachment_ids" widget="many2many_binary" />
                            </page>
                        </notebook>
                    </sheet>
                    <chatter />
                </form>
            </field>
        </record>
        <record id="action_sc_certificate_registration" model="ir.actions.act_window">
            <field name="name">证照登记</field>
            <field name="res_model">sc.document.admin.document</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="smart_construction_core.view_sc_document_admin_document_search" />
            <field name="domain">[('fact_type', '=', 'certificate_registration')]</field>
            <field name="context">{'default_fact_type': 'certificate_registration', 'search_default_certificate_registration': 1}</field>
            <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_business_initiator'), ref('smart_construction_core.group_sc_cap_business_config_admin')])]" />
        </record>
        <record id="action_sc_document_borrow" model="ir.actions.act_window">
            <field name="name">借阅申请</field>
            <field name="res_model">sc.document.admin.document</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="smart_construction_core.view_sc_document_admin_document_search" />
            <field name="domain">[('fact_type', '=', 'document_borrow')]</field>
            <field name="context">{'default_fact_type': 'document_borrow', 'search_default_document_borrow': 1}</field>
            <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_business_initiator'), ref('smart_construction_core.group_sc_cap_business_config_admin')])]" />
        </record>
        <menuitem id="menu_sc_document_admin_center" name="资料证照" parent="smart_construction_core.menu_sc_root" sequence="58" groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_business_config_admin" />
        <menuitem id="menu_sc_certificate_registration" name="证照登记" parent="smart_construction_core.menu_sc_document_admin_center" action="smart_construction_core.action_sc_certificate_registration" sequence="10" groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_business_config_admin" />
        <menuitem id="menu_sc_document_borrow" name="借阅申请" parent="smart_construction_core.menu_sc_document_admin_center" action="smart_construction_core.action_sc_document_borrow" sequence="20" groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_business_config_admin" />
    </data>
</odoo>
