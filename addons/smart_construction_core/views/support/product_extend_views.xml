<odoo>
    <record id="view_sc_material_catalog_search" model="ir.ui.view">
        <field name="name">sc.material.catalog.search</field>
        <field name="model">sc.material.catalog</field>
        <field name="arch" type="xml">
            <search string="材料档案">
                <field name="code"/>
                <field name="name"/>
                <field name="spec_model"/>
                <field name="uom_text"/>
                <field name="category_id"/>
                <field name="company_id"/>
                <field name="project_id"/>
                <filter string="历史迁移" name="legacy" domain="[('source_origin', '=', 'legacy')]"/>
                <filter string="新系统登记" name="manual" domain="[('source_origin', '=', 'manual')]"/>
                <filter string="按分类" name="group_category" context="{'group_by': 'category_id'}"/>
                <filter string="按公司" name="group_company" context="{'group_by': 'company_id'}"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按单位" name="group_uom" context="{'group_by': 'uom_text'}"/>
                <filter string="按来源" name="group_source" context="{'group_by': 'source_origin'}"/>
            </search>
        </field>
    </record>

    <record id="action_sc_material_product_template" model="ir.actions.act_window">
        <field name="name">材料档案</field>
        <field name="res_model">sc.material.catalog</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_material_catalog_search"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">创建材料档案</p>
        </field>
    </record>

    <record id="view_sc_material_catalog_tree" model="ir.ui.view">
        <field name="name">sc.material.catalog.tree</field>
        <field name="model">sc.material.catalog</field>
        <field name="arch" type="xml">
            <tree string="材料档案">
                <field name="code"/>
                <field name="name"/>
                <field name="spec_model"/>
                <field name="uom_text"/>
                <field name="aux_uom_text"/>
                <field name="planned_price"/>
                <field name="internal_price"/>
                <field name="category_id"/>
                <field name="company_id"/>
                <field name="project_id"/>
                <field name="depth"/>
                <field name="short_pinyin"/>
                <field name="source_origin"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="action_sc_material_price_library" model="ir.actions.act_window">
        <field name="name">材料价格库</field>
        <field name="res_model">sc.material.price</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_material': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">创建材料价格记录</p>
        </field>
    </record>

    <record id="view_sc_material_price_tree" model="ir.ui.view">
        <field name="name">sc.material.price.tree</field>
        <field name="model">sc.material.price</field>
        <field name="arch" type="xml">
            <tree string="材料价格库" default_order="effective_date desc, id desc">
                <field name="material_catalog_id"/>
                <field name="company_id"/>
                <field name="spec_model"/>
                <field name="uom_text"/>
                <field name="supplier_id"/>
                <field name="project_id"/>
                <field name="price_type"/>
                <field name="unit_price"/>
                <field name="currency_id" invisible="1"/>
                <field name="tax_rate"/>
                <field name="tax_included"/>
                <field name="effective_date"/>
                <field name="expiry_date"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_material_price_form" model="ir.ui.view">
        <field name="name">sc.material.price.form</field>
        <field name="model">sc.material.price</field>
        <field name="arch" type="xml">
            <form string="材料价格库">
                <sheet>
                    <group>
                        <group>
                            <field name="material_catalog_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="supplier_id"/>
                            <field name="project_id"/>
                            <field name="price_type"/>
                        </group>
                        <group>
                            <field name="unit_price"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="tax_rate"/>
                            <field name="tax_included"/>
                            <field name="effective_date"/>
                            <field name="expiry_date"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="材料信息">
                        <group>
                            <field name="spec_model" readonly="1"/>
                            <field name="uom_text" readonly="1"/>
                        </group>
                    </group>
                    <group string="来源追溯">
                        <group>
                            <field name="source_model"/>
                            <field name="source_res_id"/>
                            <field name="source_type"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_material_price_search" model="ir.ui.view">
        <field name="name">sc.material.price.search</field>
        <field name="model">sc.material.price</field>
        <field name="arch" type="xml">
            <search string="材料价格库">
                <field name="material_catalog_id"/>
                <field name="supplier_id"/>
                <field name="project_id"/>
                <field name="company_id"/>
                <field name="price_type"/>
                <field name="spec_model"/>
                <filter string="有效" name="active" domain="[('active', '=', True)]"/>
                <filter string="报价" name="quote" domain="[('price_type', '=', 'quote')]"/>
                <filter string="合同价" name="contract" domain="[('price_type', '=', 'contract')]"/>
                <filter string="按材料" name="group_material" context="{'group_by': 'material_catalog_id'}"/>
                <filter string="按公司" name="group_company" context="{'group_by': 'company_id'}"/>
                <filter string="按供应商" name="group_supplier" context="{'group_by': 'supplier_id'}"/>
                <filter string="按类型" name="group_type" context="{'group_by': 'price_type'}"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_material_catalog_form" model="ir.ui.view">
        <field name="name">sc.material.catalog.form</field>
        <field name="model">sc.material.catalog</field>
        <field name="arch" type="xml">
            <form string="材料档案">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="spec_model"/>
                            <field name="category_id"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="project_id"/>
                            <field name="source_origin"/>
                            <field name="depth"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="单位与价格">
                        <group>
                            <field name="uom_text"/>
                            <field name="aux_uom_text"/>
                        </group>
                        <group>
                            <field name="planned_price"/>
                            <field name="internal_price"/>
                        </group>
                    </group>
                    <group string="历史来源">
                    </group>
                    <group>
                        <field name="remark"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_product_template_form_sc_cost" model="ir.ui.view">
        <field name="name">product.template.form.sc.cost</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="activity_exception_decoration" invisible="1"/>
            </xpath>
            <xpath expr="//page[@name='general_information']/group/group" position="after">
                <group string="成本控制">
                    <field name="default_cost_code_id"/>
                </group>
                <group string="历史物料来源">
                </group>
            </xpath>
        </field>
    </record>
</odoo>
