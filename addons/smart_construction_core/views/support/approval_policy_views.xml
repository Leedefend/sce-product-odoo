<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sc_approval_policy_search" model="ir.ui.view">
        <field name="name">sc.approval.policy.search</field>
        <field name="model">sc.approval.policy</field>
        <field name="arch" type="xml">
            <search string="审批规则">
                <field name="name"/>
                <field name="code"/>
                <field name="target_model"/>
                <filter name="filter_required" string="已启用审批" domain="[('approval_required', '=', True)]"/>
                <filter name="filter_configurable" string="业务可配置" domain="[('runtime_state', 'in', ['tier_validation', 'document_state', 'policy_only'])]"/>
                <filter name="filter_active" string="启用" domain="[('active', '=', True)]"/>
                <group expand="0" string="分组">
                    <filter name="group_by_model" string="业务单据" context="{'group_by': 'target_model'}"/>
                    <filter name="group_by_runtime" string="执行状态" context="{'group_by': 'runtime_state'}"/>
                    <filter name="group_by_group" string="默认审批岗位" context="{'group_by': 'manager_scope_key'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sc_approval_policy_tree" model="ir.ui.view">
        <field name="name">sc.approval.policy.tree</field>
        <field name="model">sc.approval.policy</field>
        <field name="arch" type="xml">
            <tree string="审批规则" decoration-muted="not active">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="target_model"/>
                <field name="approval_required" string="启用审批"/>
                <field name="trigger"/>
                <field name="mode"/>
                <field name="runtime_state"/>
                <field name="manager_scope_key"/>
                <field name="step_count"/>
                <field name="active" string="规则有效"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_approval_policy_form" model="ir.ui.view">
        <field name="name">sc.approval.policy.form</field>
        <field name="model">sc.approval.policy</field>
        <field name="arch" type="xml">
            <form string="审批规则">
                <sheet>
                    <group string="业务规则">
                        <group string="适用业务">
                            <field name="name" string="规则名称"/>
                            <field name="target_model" string="业务单据"/>
                            <field name="approval_required" string="启用审批"/>
                        </group>
                        <group string="执行方式">
                            <field name="trigger" string="触发时点"/>
                            <field name="mode" string="审批方式"/>
                            <field name="manager_scope_key" string="默认审批岗位"/>
                            <field name="step_count" readonly="1" string="步骤数"/>
                        </group>
                    </group>
                    <group string="系统承载">
                        <group>
                            <field name="runtime_state" string="执行状态"/>
                            <field name="active" string="规则有效"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" string="公司"/>
                            <field name="manager_group_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="审批步骤">
                            <field name="step_ids" string="审批步骤">
                                <tree editable="bottom" decoration-muted="not active">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="步骤名称"/>
                                    <field name="approval_scope_key" string="审批岗位"/>
                                    <field name="approve_group_id" column_invisible="1"/>
                                    <field name="amount_min" string="金额下限"/>
                                    <field name="amount_max" string="金额上限"/>
                                    <field name="active" string="启用"/>
                                </tree>
                                <form string="审核步骤">
                                    <group string="步骤配置">
                                        <group string="审批节点">
                                            <field name="name" string="步骤名称"/>
                                            <field name="approval_scope_key" string="审批岗位"/>
                                            <field name="approve_group_id" invisible="1"/>
                                            <field name="active" string="启用"/>
                                        </group>
                                        <group string="适用条件">
                                            <field name="sequence" string="顺序"/>
                                            <field name="amount_min" string="金额下限"/>
                                            <field name="amount_max" string="金额上限"/>
                                            <field name="condition_note" string="备注"/>
                                        </group>
                                    </group>
                                    <field name="note" string="备注"/>
                                </form>
                            </field>
                        </page>
                        <page string="业务说明">
                            <field name="note" nolabel="1" placeholder="填写该审批规则的业务口径、适用范围和特殊说明。"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_approval_policy" model="ir.actions.act_window">
        <field name="name">审批规则</field>
        <field name="res_model">sc.approval.policy</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_approval_policy_search"/>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_business_config_admin'))]"/>
    </record>

    <menuitem id="menu_sc_approval_policy"
              name="审批规则"
              parent="smart_construction_core.menu_sc_business_base_config_group"
              action="action_sc_approval_policy"
              sequence="30"
              groups="smart_construction_core.group_sc_cap_business_config_admin"/>
</odoo>
