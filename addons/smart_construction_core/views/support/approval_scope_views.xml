<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sc_approval_scope_tree" model="ir.ui.view">
        <field name="name">sc.approval.scope.tree</field>
        <field name="model">sc.approval.scope</field>
        <field name="arch" type="xml">
            <tree string="审批岗位人员" create="0" delete="0">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="user_count"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_approval_scope_form" model="ir.ui.view">
        <field name="name">sc.approval.scope.form</field>
        <field name="model">sc.approval.scope</field>
        <field name="arch" type="xml">
            <form string="审批岗位人员" create="0" delete="0">
                <header>
                    <button name="action_open_add_user_wizard"
                            type="object"
                            string="新增人员"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="scope_key" readonly="1"/>
                            <field name="user_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="group_id" invisible="1"/>
                            <field name="note"/>
                        </group>
                    </group>
                    <group string="人员">
                        <field name="user_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_approval_scope_user_wizard_form" model="ir.ui.view">
        <field name="name">sc.approval.scope.user.wizard.form</field>
        <field name="model">sc.approval.scope.user.wizard</field>
        <field name="arch" type="xml">
            <form string="新增审批人员">
                <group>
                    <field name="scope_id"/>
                    <field name="name"/>
                    <field name="login"/>
                    <field name="email"/>
                    <field name="password" password="True"/>
                </group>
                <footer>
                    <button name="action_create_user" type="object" string="创建并加入岗位" class="btn-primary"/>
                    <button string="取消" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sc_approval_scope" model="ir.actions.act_window">
        <field name="name">审批岗位人员</field>
        <field name="res_model">sc.approval.scope</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_business_config_admin'))]"/>
    </record>

    <menuitem id="menu_sc_approval_scope"
              name="审批岗位人员"
              parent="smart_construction_core.menu_sc_business_base_config_group"
              action="action_sc_approval_scope"
              sequence="31"
              groups="smart_construction_core.group_sc_cap_business_config_admin"/>
</odoo>
