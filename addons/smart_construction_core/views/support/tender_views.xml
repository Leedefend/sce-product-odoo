<odoo>
    <!-- List view -->
    <record id="view_tender_bid_tree" model="ir.ui.view">
        <field name="name">tender.bid.tree</field>
        <field name="model">tender.bid</field>
        <field name="arch" type="xml">
            <tree string="投标管理" default_order="project_id, id desc">
                <field name="project_id"/>
                <field name="operation_strategy"/>
                <field name="tender_name"/>
                <field name="tender_round"/>
                <field name="applicant_name"/>
                <field name="apply_date"/>
                <field name="owner_id"/>
                <field name="bid_amount" sum="投标金额合计"/>
                <field name="amount_total" sum="费用金额合计"/>
                <field name="state"/>
                <field name="created_time" optional="hide"/>
                <field name="deadline"/>
                <field name="open_date"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_tender_bid_form" model="ir.ui.view">
        <field name="name">tender.bid.form</field>
        <field name="model">tender.bid</field>
        <field name="arch" type="xml">
            <form string="投标记录">
                <header>
                    <button name="action_to_estimating" type="object" string="进入造价测算"
                            class="oe_highlight"
                            modifiers="{'invisible': [['state','!=','prepare']]}"/>
                    <button name="action_to_submitted" type="object" string="提交投标"
                            class="oe_highlight"
                            modifiers="{'invisible': [['state','not in',['prepare','estimating']]]}"/>
                    <button name="action_to_waiting" type="object" string="等待开标"
                            class="oe_highlight"
                            modifiers="{'invisible': [['state','!=','submitted']]}"/>
                    <button name="action_mark_won" type="object" string="中标"
                            class="oe_highlight"
                            modifiers="{'invisible': [['state','not in',['submitted','waiting']]]}"/>
                    <button name="action_mark_lost" type="object" string="未中标"
                            modifiers="{'invisible': [['state','not in',['submitted','waiting']]]}"/>
                    <button name="action_to_prepare" type="object" string="重回准备"
                            modifiers="{'invisible': [['state','=','prepare']]}"/>
                    <!-- 单一状态条：可点击，高亮随状态自动切换 -->
                    <field name="state" widget="statusbar"
                           options="{'clickable': '1'}"
                           statusbar_visible="prepare,estimating,submitted,waiting,won,lost"
                           statusbar_colors="{'won':'success','lost':'danger','waiting':'warning','estimating':'info'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(smart_construction_core.action_project_wbs)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-sitemap"
                                modifiers="{'invisible': [['project_id','=',False]]}">
                            <field name="project_id" invisible="1"/>
                            <span class="o_stat_text">工程结构</span>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" required="1"/>
                            <field name="operation_strategy" readonly="1"/>
                            <field name="tender_name" required="1"/>
                            <field name="tender_round"/>
                            <field name="applicant_name"/>
                            <field name="apply_date"/>
                            <field name="owner_id"/>
                            <field name="bid_amount"/>
                            <field name="amount_total" readonly="1"/>
                        </group>
                        <group>
                            <field name="created_time"/>
                            <field name="deadline"/>
                            <field name="open_date"/>
                            <field name="contract_id" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="清单">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="spec"/>
                                    <field name="uom_id"/>
                                    <field name="quantity"/>
                                    <field name="price"/>
                                    <field name="amount"/>
                                </tree>
                            </field>
                        </page>
                        <page string="备注">
                            <field name="note"/>
                        </page>
                        <page string="技术标附件">
                            <field name="tech_attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="商务标附件">
                            <field name="biz_attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="历史来源">
                            <group>
                                <group>
                                </group>
                                <group>
                                </group>
                            </group>
                            <group>
                            </group>
                        </page>
                        <page string="平台范围元数据" name="platform_scope_metadata">
                            <group>
                                <group>
                                    <field name="business_scope_key"/>
                                    <field name="business_direction"/>
                                </group>
                                <group>
                                    <field name="carrier_type"/>
                                    <field name="carrier_model"/>
                                    <field name="carrier_res_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="标书购买">
                            <field name="doc_purchase_ids" context="{'default_bid_id': context.get('active_id')}">
                                <tree editable="bottom">
                                    <field name="applicant_id"/>
                                    <field name="apply_date"/>
                                    <field name="amount"/>
                                    <field name="payment_method"/>
                                    <field name="receipt_partner_name"/>
                                    <field name="receipt_bank_account"/>
                                    <field name="invoice_no"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="现场踏勘">
                            <field name="survey_ids" context="{'default_bid_id': context.get('active_id')}">
                                <tree editable="bottom">
                                    <field name="survey_date"/>
                                    <field name="location"/>
                                    <field name="member_ids"/>
                                    <field name="issue_notes"/>
                                </tree>
                            </field>
                        </page>
                        <page string="文件审查">
                            <field name="review_ids" context="{'default_bid_id': context.get('active_id')}">
                                <tree editable="bottom">
                                    <field name="version"/>
                                    <field name="reviewer_ids"/>
                                    <field name="comment"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="开标登记">
                            <field name="opening_ids" context="{'default_bid_id': context.get('active_id')}">
                                <tree editable="bottom">
                                    <field name="open_time"/>
                                    <field name="result"/>
                                    <field name="win_price"/>
                                    <field name="remark"/>
                                </tree>
                            </field>
                        </page>
                        <page string="保证金">
                            <field name="guarantee_ids" context="{'default_bid_id': context.get('active_id')}">
                                <tree editable="bottom">
                                    <field name="type"/>
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="bank_account_id"/>
                                    <field name="remark"/>
                                </tree>
                            </field>
                            <group>
                                <field name="guarantee_total" readonly="1"/>
                                <field name="guarantee_outstanding" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_tender_bid_search" model="ir.ui.view">
        <field name="name">tender.bid.search</field>
        <field name="model">tender.bid</field>
        <field name="arch" type="xml">
            <search string="投标管理">
                <field name="project_id"/>
                <field name="tender_name"/>
                <field name="applicant_name"/>
                <field name="owner_id"/>
                <filter string="中标" name="won" domain="[('state','=','won')]"/>
                <group expand="1" string="分组">
                    <filter string="投标项目名称" name="group_tender_project_name" context="{'group_by':'project_id'}"/>
                    <filter string="按项目" name="group_project" context="{'group_by':'project_id'}"/>
                    <filter string="按申请日期" name="group_apply_date" context="{'group_by':'apply_date'}"/>
                    <filter string="按负责人" name="group_owner" context="{'group_by':'owner_id'}"/>
                    <filter string="按经营策略" name="group_operation_strategy" context="{'group_by':'operation_strategy'}"/>
                    <filter string="按创建时间" name="group_create_date" context="{'group_by':'create_date'}"/>
                    <filter string="按录入时间" name="group_created_time" context="{'group_by':'created_time'}"/>
                    <filter string="按登记时间" name="group_source_created_at" context="{'group_by':'source_created_at'}"/>
                    <filter string="按状态" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_tender_opening_search" model="ir.ui.view">
        <field name="name">tender.opening.search</field>
        <field name="model">tender.opening</field>
        <field name="arch" type="xml">
            <search string="开标记录">
                <field name="bid_id"/>
                <field name="project_id"/>
                <field name="result"/>
                <filter string="中标" name="result_won" domain="[('result', '=', 'won')]"/>
                <filter string="未中标" name="result_lost" domain="[('result', '=', 'lost')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按结果" name="group_result" context="{'group_by': 'result'}"/>
            </search>
        </field>
    </record>

    <record id="view_tender_opening_tree" model="ir.ui.view">
        <field name="name">tender.opening.tree</field>
        <field name="model">tender.opening</field>
        <field name="arch" type="xml">
            <tree string="开标记录" default_order="open_time desc, id desc">
                <field name="open_time"/>
                <field name="project_id"/>
                <field name="bid_id"/>
                <field name="result"/>
                <field name="win_price"/>
                <field name="remark"/>
            </tree>
        </field>
    </record>

    <record id="view_tender_opening_form" model="ir.ui.view">
        <field name="name">tender.opening.form</field>
        <field name="model">tender.opening</field>
        <field name="arch" type="xml">
            <form string="开标记录">
                <header>
                    <field name="result" widget="statusbar" statusbar_visible="pending,won,lost,backup"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="bid_id" required="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="open_time"/>
                        </group>
                        <group>
                            <field name="win_price"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="competitor_ids">
                            <tree editable="bottom">
                                <field name="name"/>
                                <field name="quote"/>
                                <field name="rank"/>
                                <field name="remark"/>
                            </tree>
                        </field>
                    </group>
                    <group>
                        <field name="remark"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tender_guarantee_search" model="ir.ui.view">
        <field name="name">tender.guarantee.search</field>
        <field name="model">tender.guarantee</field>
        <field name="arch" type="xml">
            <search string="投标保证金">
                <field name="bid_id"/>
                <field name="project_id"/>
                <field name="type"/>
                <field name="state"/>
                <filter string="缴纳" name="type_out" domain="[('type', '=', 'out')]"/>
                <filter string="退回" name="type_return" domain="[('type', '=', 'return')]"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="已确认" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="已取消" name="cancel" domain="[('state', '=', 'cancel')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按日期" name="group_date" context="{'group_by': 'date'}"/>
                <filter string="按类型" name="group_type" context="{'group_by': 'type'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_tender_doc_purchase_search" model="ir.ui.view">
        <field name="name">tender.doc.purchase.search</field>
        <field name="model">tender.doc.purchase</field>
        <field name="arch" type="xml">
            <search string="投标报名费申请">
                <field name="bid_id"/>
                <field name="project_id"/>
                <field name="applicant_id"/>
                <field name="invoice_no"/>
                <field name="payment_method"/>
                <field name="receipt_partner_id"/>
                <field name="receipt_partner_name"/>
                <field name="receipt_payee_name"/>
                <field name="receipt_bank_name"/>
                <field name="receipt_bank_account"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="审批中" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="已通过" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="已驳回" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="分组">
                    <filter string="按投标" name="group_bid" context="{'group_by': 'bid_id'}"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按申请日期" name="group_apply_date" context="{'group_by': 'apply_date'}"/>
                    <filter string="按收款单位" name="group_receipt_partner" context="{'group_by': 'receipt_partner_id'}"/>
                    <filter string="按申请人" name="group_applicant" context="{'group_by': 'applicant_id'}"/>
                    <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_tender_doc_purchase_tree" model="ir.ui.view">
        <field name="name">tender.doc.purchase.tree</field>
        <field name="model">tender.doc.purchase</field>
        <field name="arch" type="xml">
            <tree string="投标报名费申请" default_order="apply_date desc, id desc">
                <field name="apply_date"/>
                <field name="project_id"/>
                <field name="bid_id"/>
                <field name="applicant_id"/>
                <field name="amount" sum="报名费合计"/>
                <field name="payment_method"/>
                <field name="receipt_partner_id"/>
                <field name="receipt_payee_name"/>
                <field name="receipt_bank_name"/>
                <field name="receipt_bank_account"/>
                <field name="invoice_no"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_tender_doc_purchase_form" model="ir.ui.view">
        <field name="name">tender.doc.purchase.form</field>
        <field name="model">tender.doc.purchase</field>
        <field name="arch" type="xml">
            <form string="投标报名费申请">
                <header>
                    <button name="action_submit" type="object" string="提交" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="通过" class="btn-primary" invisible="state not in ['draft', 'submitted']"/>
                    <button name="action_reject" type="object" string="驳回" invisible="state in ['approved', 'rejected']"/>
                    <button name="action_reset_draft" type="object" string="重置草稿" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group string="申请信息">
                            <field name="bid_id" required="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="applicant_id"/>
                            <field name="apply_date" required="1"/>
                        </group>
                        <group string="费用">
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="payment_method"/>
                            <field name="invoice_no"/>
                        </group>
                    </group>
                    <group string="收款信息">
                        <group>
                            <field name="receipt_partner_id"/>
                            <field name="receipt_partner_name" readonly="1"/>
                            <field name="receipt_payee_name"/>
                        </group>
                        <group>
                            <field name="receipt_bank_name"/>
                            <field name="receipt_bank_account"/>
                        </group>
                    </group>
                    <group string="历史来源">
                        <group>
                        </group>
                        <group>
                        </group>
                    </group>
                    <group string="备注与附件">
                        <field name="remark"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tender_guarantee_tree" model="ir.ui.view">
        <field name="name">tender.guarantee.tree</field>
        <field name="model">tender.guarantee</field>
        <field name="arch" type="xml">
            <tree string="投标保证金" default_order="date desc, id desc">
                <field name="date"/>
                <field name="project_id"/>
                <field name="bid_id"/>
                <field name="type"/>
                <field name="state"/>
                <field name="amount" sum="保证金合计"/>
                <field name="receipt_bank_account_id"/>
                <field name="bank_account_id"/>
                <field name="remark"/>
            </tree>
        </field>
    </record>

    <record id="view_tender_guarantee_form" model="ir.ui.view">
        <field name="name">tender.guarantee.form</field>
        <field name="model">tender.guarantee</field>
        <field name="arch" type="xml">
            <form string="投标保证金">
                <header>
                    <button name="action_confirm" type="object" string="确认" class="btn-primary" invisible="state == 'confirmed'"/>
                    <button name="action_cancel" type="object" string="取消" invisible="state == 'cancel'"/>
                    <button name="action_reset_draft" type="object" string="重置草稿" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancel"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="bid_id" required="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="date" required="1"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="账户信息">
                        <field name="receipt_bank_account_id"/>
                        <field name="bank_account_id"/>
                    </group>
                    <group string="备注与附件">
                        <field name="remark"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_tender_bid" model="ir.actions.act_window">
        <field name="name">投标管理</field>
        <field name="res_model">tender.bid</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_tender_bid_search"/>
        <field name="context">{'default_state': 'prepare'}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_project_read'))]"/>
    </record>
    <record id="action_sc_tender_registration" model="ir.actions.act_window">
        <field name="name">投标报名管理</field>
        <field name="res_model">tender.bid</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_tender_bid_search"/>
        <field name="domain">[]</field>
        <field name="context">{'default_state': 'prepare'}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_project_read'))]"/>
    </record>
    <record id="action_sc_tender_registration_fee" model="ir.actions.act_window">
        <field name="name">投标报名费申请</field>
        <field name="res_model">tender.doc.purchase</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_tender_doc_purchase_search"/>
        <field name="domain">[]</field>
        <field name="context">{'search_default_group_project': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_project_user')), (4, ref('smart_construction_core.group_sc_cap_project_manager'))]"/>
    </record>

    <!-- Project form: 投标页签 -->
    <record id="view_project_form_inherit_tender" model="ir.ui.view">
        <field name="name">project.project.form.inherit.tender</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(smart_construction_core.action_tender_bid)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-gavel"
                        groups="smart_construction_core.group_sc_cap_project_user,smart_construction_core.group_sc_cap_project_manager"
                        context="{'search_default_project_id': id, 'default_project_id': id}"
                        domain="[('project_id','=', id)]">
                    <field name="tender_count" widget="statinfo" string="投标"/>
                </button>
            </xpath>
            <!-- 若项目视图已定义 sc_tender 页签，则复用并替换其内容，避免重复新增投标管理页 -->
            <xpath expr="//sheet/notebook/page[@name='sc_tender']" position="replace">
                <page string="投标管理" name="sc_tender"
                      groups="smart_construction_core.group_sc_cap_project_user,smart_construction_core.group_sc_cap_project_manager">
                    <field name="tender_bid_ids" context="{'default_project_id': id, 'default_state': 'prepare'}">
                        <tree string="投标记录" editable="bottom">
                            <field name="tender_name"/>
                            <field name="tender_round"/>
                            <field name="owner_id"/>
                            <field name="bid_amount"/>
                            <field name="amount_total"/>
                            <field name="state"/>
                            <field name="deadline"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
