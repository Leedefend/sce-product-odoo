<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_finance_project_counterparty_position_search" model="ir.ui.view">
        <field name="name">sc.finance.project.counterparty.position.search</field>
        <field name="model">sc.finance.project.counterparty.position</field>
        <field name="arch" type="xml">
            <search string="项目与对象资金往来">
                <field name="project_id"/>
                <field name="counterparty_name"/>
                <field name="partner_id"/>
                <field name="counterparty_project_id"/>
                <filter string="公司" name="counterparty_company" domain="[('counterparty_type', '=', 'company')]"/>
                <filter string="项目" name="counterparty_project" domain="[('counterparty_type', '=', 'project')]"/>
                <filter string="往来单位/人员" name="counterparty_partner" domain="[('counterparty_type', '=', 'partner')]"/>
                <filter string="有借还调拨" name="has_interfund" domain="[('interfund_source_line_count', '&gt;', 0)]"/>
                <filter string="有收付款" name="has_finance" domain="[('finance_source_line_count', '&gt;', 0)]"/>
                <group expand="0" string="分组">
                    <filter string="项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="对象类型" name="group_counterparty_type" context="{'group_by': 'counterparty_type'}"/>
                <filter string="对方单位/人员" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="对方项目" name="group_counterparty_project" context="{'group_by': 'counterparty_project_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sc_finance_project_counterparty_position_tree" model="ir.ui.view">
        <field name="name">sc.finance.project.counterparty.position.tree</field>
        <field name="model">sc.finance.project.counterparty.position</field>
        <field name="arch" type="xml">
            <tree string="项目与对象资金往来" create="0" edit="0" delete="0">
                <field name="project_id"/>
                <field name="counterparty_type"/>
                <field name="counterparty_name"/>
                <field name="counterparty_project_id"/>
                <field name="partner_id"/>
                <field name="source_line_count" sum="全部明细数"/>
                <field name="finance_balance_effect" sum="收付款余额影响"/>
                <field name="interfund_net_amount" sum="借还调拨净流入"/>
                <field name="combined_balance_effect" sum="资金余额影响"/>
                <field name="combined_cash_net_amount" sum="现金净额"/>
                <field name="interfund_inflow_amount" sum="借还调拨流入"/>
                <field name="interfund_outflow_amount" sum="借还调拨流出"/>
                <field name="internal_transfer_amount" sum="账户调拨"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_finance_project_counterparty_position_form" model="ir.ui.view">
        <field name="name">sc.finance.project.counterparty.position.form</field>
        <field name="model">sc.finance.project.counterparty.position</field>
        <field name="arch" type="xml">
            <form string="项目与对象资金往来" create="0" edit="0" delete="0">
                <header>
                    <button name="action_open_finance_facts" type="object" string="查看收付款明细" class="btn-primary"/>
                    <button name="action_open_interfund_facts" type="object" string="查看借还调拨明细" class="btn-secondary"/>
                    <button name="action_open_company_borrow_entry" type="object" string="项目借公司款" class="btn-secondary" invisible="counterparty_type != 'company'"/>
                    <button name="action_open_company_repay_entry" type="object" string="项目还公司款" class="btn-secondary" invisible="counterparty_type != 'company'"/>
                    <button name="action_open_contractor_borrow_entry" type="object" string="承包人借项目款" class="btn-secondary" invisible="counterparty_type != 'partner'"/>
                    <button name="action_open_contractor_repay_entry" type="object" string="承包人还项目款" class="btn-secondary" invisible="counterparty_type != 'partner'"/>
                    <button name="action_open_account_transfer_entry" type="object" string="账户调拨" class="btn-secondary" invisible="counterparty_type not in ['company', 'project', 'internal']"/>
                </header>
                <sheet>
                    <group>
                        <field name="display_name"/>
                        <field name="project_id"/>
                        <field name="company_id"/>
                        <field name="currency_id"/>
                        <field name="coverage_note"/>
                    </group>
                    <group string="往来对象">
                        <field name="counterparty_type"/>
                        <field name="counterparty_name"/>
                        <field name="counterparty_project_id"/>
                        <field name="partner_id"/>
                    </group>
                    <group string="明细数量">
                        <field name="finance_source_line_count"/>
                        <field name="interfund_source_line_count"/>
                        <field name="source_line_count"/>
                    </group>
                    <group string="资金影响">
                        <field name="finance_balance_effect"/>
                        <field name="finance_cash_in_amount"/>
                        <field name="finance_cash_out_amount"/>
                        <field name="finance_cash_net_amount"/>
                        <field name="interfund_inflow_amount"/>
                        <field name="interfund_outflow_amount"/>
                        <field name="interfund_net_amount"/>
                        <field name="internal_transfer_amount"/>
                        <field name="combined_balance_effect"/>
                        <field name="combined_cash_net_amount"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_finance_project_counterparty_position_pivot" model="ir.ui.view">
        <field name="name">sc.finance.project.counterparty.position.pivot</field>
        <field name="model">sc.finance.project.counterparty.position</field>
        <field name="arch" type="xml">
            <pivot string="项目与对象资金往来">
                <field name="project_id" type="row"/>
                <field name="counterparty_type" type="col"/>
                <field name="combined_balance_effect" type="measure"/>
                <field name="combined_cash_net_amount" type="measure"/>
                <field name="source_line_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_sc_finance_project_counterparty_position" model="ir.actions.act_window">
        <field name="name">项目与对象资金往来</field>
        <field name="res_model">sc.finance.project.counterparty.position</field>
        <field name="view_mode">tree,pivot,form</field>
        <field name="search_view_id" ref="view_sc_finance_project_counterparty_position_search"/>
        <field name="context">{'search_default_group_project': 1, 'search_default_group_counterparty_type': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')), (4, ref('smart_construction_core.group_sc_cap_finance_user')), (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
    </record>
</odoo>
