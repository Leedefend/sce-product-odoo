<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_p1_relationship_suggestion_search" model="ir.ui.view">
        <field name="name">sc.p1.relationship.suggestion.search</field>
        <field name="model">sc.p1.relationship.suggestion</field>
        <field name="arch" type="xml">
            <search string="P1关系建议">
                <field name="source_record_name"/>
                <field name="candidate_value"/>
                <field name="partner_id"/>
                <field name="project_id"/>
                <filter string="可自动建议" name="auto_candidate" domain="[('recommendation', '=', 'auto_candidate')]"/>
                <filter string="需人工确认" name="manual_review_candidate" domain="[('recommendation', '=', 'manual_review_candidate')]"/>
                <group expand="0" string="分组">
                    <filter string="业务域" name="group_source_family" context="{'group_by': 'source_family'}"/>
                    <filter string="来源模型" name="group_source_model" context="{'group_by': 'source_model'}"/>
                    <filter string="来源字段" name="group_candidate_field" context="{'group_by': 'candidate_field'}"/>
                    <filter string="建议单位" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="项目" name="group_project" context="{'group_by': 'project_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sc_p1_relationship_suggestion_tree" model="ir.ui.view">
        <field name="name">sc.p1.relationship.suggestion.tree</field>
        <field name="model">sc.p1.relationship.suggestion</field>
        <field name="arch" type="xml">
            <tree string="P1关系建议" create="0" edit="0" delete="0">
                <field name="source_family"/>
                <field name="source_model"/>
                <field name="source_record_name"/>
                <field name="project_id"/>
                <field name="candidate_field"/>
                <field name="candidate_value"/>
                <field name="partner_id"/>
                <field name="match_basis"/>
                <field name="confidence_score"/>
                <field name="recommendation"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_p1_relationship_suggestion_form" model="ir.ui.view">
        <field name="name">sc.p1.relationship.suggestion.form</field>
        <field name="model">sc.p1.relationship.suggestion</field>
        <field name="arch" type="xml">
            <form string="P1关系建议" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="display_name"/>
                        <field name="coverage_note"/>
                    </group>
                    <group string="来源">
                        <field name="source_family"/>
                        <field name="source_model"/>
                        <field name="source_res_id"/>
                        <field name="source_record_name"/>
                        <field name="company_id"/>
                        <field name="currency_id"/>
                        <field name="project_id"/>
                    </group>
                    <group string="建议关系">
                        <field name="target_model"/>
                        <field name="target_field"/>
                        <field name="partner_id"/>
                        <field name="candidate_field"/>
                        <field name="candidate_value"/>
                        <field name="match_basis"/>
                        <field name="confidence_score"/>
                        <field name="recommendation"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_p1_relationship_suggestion_pivot" model="ir.ui.view">
        <field name="name">sc.p1.relationship.suggestion.pivot</field>
        <field name="model">sc.p1.relationship.suggestion</field>
        <field name="arch" type="xml">
            <pivot string="P1关系建议">
                <field name="source_family" type="row"/>
                <field name="source_model" type="row"/>
                <field name="recommendation" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="action_sc_p1_relationship_suggestion" model="ir.actions.act_window">
        <field name="name">P1关系建议</field>
        <field name="res_model">sc.p1.relationship.suggestion</field>
        <field name="view_mode">tree,pivot,form</field>
        <field name="search_view_id" ref="view_sc_p1_relationship_suggestion_search"/>
        <field name="context">{'search_default_group_source_family': 1, 'search_default_group_source_model': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_business_config_admin')), (4, ref('smart_construction_core.group_sc_cap_config_admin'))]"/>
    </record>
</odoo>
