<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_company_operation_summary_search" model="ir.ui.view">
        <field name="name">sc.company.operation.summary.search</field>
        <field name="model">sc.company.operation.summary</field>
        <field name="arch" type="xml">
            <search string="公司经营情况表">
                <field name="period_label"/>
                <field name="company_id"/>
                <field name="period_year"/>
                <field name="period_month"/>
                <group expand="0" string="分组">
                    <filter string="年度" name="group_year" context="{'group_by': 'period_year'}"/>
                    <filter string="公司" name="group_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sc_company_operation_summary_tree" model="ir.ui.view">
        <field name="name">sc.company.operation.summary.tree</field>
        <field name="model">sc.company.operation.summary</field>
        <field name="arch" type="xml">
            <tree string="公司经营情况表" create="0" edit="0" delete="0">
                <field name="period_label"/>
                <field name="revenue_amount" sum="营收"/>
                <field name="deduction_management_fee_amount" sum="管理费"/>
                <field name="deduction_enterprise_income_tax_amount" sum="企业所得税"/>
                <field name="deduction_vat_surcharge_amount" sum="增值税附加"/>
                <field name="deduction_vat_surcharge_nonrefundable_amount" sum="增值税附加(不可退)"/>
                <field name="company_interest_income_amount" sum="利息公司"/>
                <field name="bid_document_fee_income_amount" sum="标书制作费"/>
                <field name="appearance_fee_income_amount" sum="出场费"/>
                <field name="certificate_fee_income_amount" sum="证书费"/>
                <field name="company_operation_income_amount" sum="公司经营收入"/>
                <field name="union_fee_income_amount" sum="工会经费"/>
                <field name="branch_annual_fee_income_amount" sum="分公司年费"/>
                <field name="disability_fund_income_amount" sum="残保金"/>
                <field name="personal_income_tax_income_amount" sum="个人所得税"/>
                <field name="income_amount" sum="收入合计"/>
                <field name="expense_amount" sum="支出合计"/>
                <field name="reimbursement_amount" sum="报销"/>
                <field name="salary_amount" sum="工资"/>
                <field name="employee_social_security_amount" sum="员工社保"/>
                <field name="certificate_social_security_amount" sum="证书社保"/>
                <field name="deduction_refund_surcharge_amount" sum="增值税附加退项目"/>
                <field name="company_enterprise_income_tax_expense_amount" sum="支出企业所得税"/>
                <field name="company_personal_income_tax_expense_amount" sum="支出个人所得税"/>
                <field name="company_vat_surcharge_tax_bureau_amount" sum="增值税附加交税务局"/>
                <field name="tender_fee_expense_amount" sum="投标费"/>
                <field name="appearance_fee_expense_amount" sum="支出出场费"/>
                <field name="company_operation_expense_amount" sum="公司经营支出"/>
                <field name="company_interest_expense_amount" sum="支出利息公司"/>
                <field name="disability_fund_expense_amount" sum="支出残保金"/>
                <field name="union_fee_expense_amount" sum="支出工会经费"/>
                <field name="service_fee_expense_amount" sum="手续费"/>
                <field name="source_line_count" sum="来源明细数"/>
                <field name="coverage_note"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_company_operation_summary_form" model="ir.ui.view">
        <field name="name">sc.company.operation.summary.form</field>
        <field name="model">sc.company.operation.summary</field>
        <field name="arch" type="xml">
            <form string="公司经营情况表" create="0" edit="0" delete="0">
                <header>
                    <button name="action_open_deduction_paid" type="object" string="扣款实缴明细" class="btn-primary" invisible="deduction_management_fee_amount == 0 and deduction_enterprise_income_tax_amount == 0 and deduction_vat_surcharge_amount == 0 and deduction_vat_surcharge_nonrefundable_amount == 0"/>
                    <button name="action_open_company_income" type="object" string="公司财务收入" class="btn-secondary" invisible="income_amount == 0"/>
                    <button name="action_open_reimbursements" type="object" string="费用报销明细" class="btn-secondary" invisible="reimbursement_amount == 0"/>
                    <button name="action_open_payroll_documents" type="object" string="工资社保来源" class="btn-secondary" invisible="salary_amount == 0 and employee_social_security_amount == 0 and certificate_social_security_amount == 0"/>
                    <button name="action_open_deduction_refunds" type="object" string="扣款退回来源" class="btn-secondary" invisible="deduction_refund_surcharge_amount == 0"/>
                    <button name="action_open_company_expenses" type="object" string="公司财务支出" class="btn-secondary" invisible="expense_amount == 0"/>
                </header>
                <sheet>
                    <group>
                        <field name="period_label"/>
                        <field name="period_year"/>
                        <field name="period_month"/>
                        <field name="company_id"/>
                        <field name="coverage_note"/>
                    </group>
                    <group>
                        <group string="收入">
                            <field name="deduction_management_fee_amount"/>
                            <field name="deduction_enterprise_income_tax_amount"/>
                            <field name="deduction_vat_surcharge_amount"/>
                            <field name="deduction_vat_surcharge_nonrefundable_amount"/>
                            <field name="company_interest_income_amount"/>
                            <field name="bid_document_fee_income_amount"/>
                            <field name="appearance_fee_income_amount"/>
                            <field name="certificate_fee_income_amount"/>
                            <field name="company_operation_income_amount"/>
                            <field name="income_amount"/>
                        </group>
                        <group string="支出">
                            <field name="reimbursement_amount"/>
                            <field name="salary_amount"/>
                            <field name="employee_social_security_amount"/>
                            <field name="certificate_social_security_amount"/>
                            <field name="deduction_refund_surcharge_amount"/>
                            <field name="company_enterprise_income_tax_expense_amount"/>
                            <field name="company_personal_income_tax_expense_amount"/>
                            <field name="company_vat_surcharge_tax_bureau_amount"/>
                            <field name="tender_fee_expense_amount"/>
                            <field name="service_fee_expense_amount"/>
                            <field name="expense_amount"/>
                        </group>
                    </group>
                    <group string="结果">
                        <field name="revenue_amount"/>
                        <field name="source_line_count"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_company_operation_summary_pivot" model="ir.ui.view">
        <field name="name">sc.company.operation.summary.pivot</field>
        <field name="model">sc.company.operation.summary</field>
        <field name="arch" type="xml">
            <pivot string="公司经营情况表">
                <field name="company_id" type="row"/>
                <field name="period_month" type="row"/>
                <field name="revenue_amount" type="measure"/>
                <field name="income_amount" type="measure"/>
                <field name="expense_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_sc_company_operation_summary_graph" model="ir.ui.view">
        <field name="name">sc.company.operation.summary.graph</field>
        <field name="model">sc.company.operation.summary</field>
        <field name="arch" type="xml">
            <graph string="公司经营情况表" type="bar">
                <field name="company_id"/>
                <field name="revenue_amount" type="measure"/>
                <field name="income_amount" type="measure"/>
                <field name="expense_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_sc_company_operation_summary" model="ir.actions.act_window">
        <field name="name">公司经营情况表</field>
        <field name="res_model">sc.company.operation.summary</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="smart_construction_core.view_sc_company_operation_summary_search"/>
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_finance_read'),
            ref('smart_construction_core.group_sc_cap_finance_user'),
            ref('smart_construction_core.group_sc_cap_finance_manager'),
            ref('smart_construction_core.group_sc_cap_cost_read'),
            ref('smart_construction_core.group_sc_cap_cost_user'),
            ref('smart_construction_core.group_sc_cap_cost_manager')
        ])]"/>
    </record>
</odoo>
