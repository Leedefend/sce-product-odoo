<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_company_contractor_responsibility_fact_search" model="ir.ui.view">
            <field name="name">sc.company.contractor.responsibility.fact.search</field>
            <field name="model">sc.company.contractor.responsibility.fact</field>
            <field name="arch" type="xml">
                <search string="公司-承包人资金责任明细">
                    <field name="source_document_no"/>
                    <field name="project_id"/>
                    <field name="partner_name"/>
                    <filter string="到款确认" name="arrival_confirmation" domain="[('responsibility_type', '=', 'arrival_confirmation')]"/>
                    <filter string="自筹垫付" name="self_funding_income" domain="[('responsibility_type', '=', 'self_funding_income')]"/>
                    <filter string="自筹退回" name="self_funding_refund" domain="[('responsibility_type', '=', 'self_funding_refund')]"/>
                    <filter string="按责任类型" name="group_responsibility_type" context="{'group_by': 'responsibility_type'}"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按承包人" name="group_partner" context="{'group_by': 'partner_name'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_company_contractor_responsibility_fact_tree" model="ir.ui.view">
            <field name="name">sc.company.contractor.responsibility.fact.tree</field>
            <field name="model">sc.company.contractor.responsibility.fact</field>
            <field name="arch" type="xml">
                <tree string="公司-承包人资金责任明细" create="0" edit="0" delete="0" default_order="document_date desc, id desc">
                    <field name="document_date"/>
                    <field name="responsibility_type"/>
                    <field name="project_id"/>
                    <field name="partner_name"/>
                    <field name="amount" sum="责任金额合计"/>
                    <field name="arrival_amount" sum="到款合计"/>
                    <field name="paid_amount" sum="拨付合计"/>
                    <field name="deducted_amount" sum="扣款合计"/>
                    <field name="self_funding_income_amount" sum="自筹垫付合计"/>
                    <field name="self_funding_refund_amount" sum="自筹退回合计"/>
                    <field name="self_funding_balance_effect" sum="自筹未退影响合计"/>
                    <field name="project_fund_status_effect" sum="项目资金状态影响合计"/>
                    <field name="contractor_responsibility_effect" sum="承包人责任影响合计"/>
                    <field name="source_menu_hint"/>
                    <field name="source_document_no"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_company_contractor_responsibility_fact_form" model="ir.ui.view">
            <field name="name">sc.company.contractor.responsibility.fact.form</field>
            <field name="model">sc.company.contractor.responsibility.fact</field>
            <field name="arch" type="xml">
                <form string="公司-承包人资金责任明细" create="0" edit="0" delete="0">
                    <header>
                        <button name="action_open_source_record" type="object" string="打开来源单据" class="btn-primary"/>
                        <button name="action_open_finance_fact" type="object" string="打开收付款事实" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="责任口径">
                                <field name="display_name"/>
                                <field name="responsibility_type"/>
                                <field name="responsibility_scope"/>
                                <field name="balance_policy"/>
                                <field name="coverage_note"/>
                            </group>
                            <group string="业务对象">
                                <field name="document_date"/>
                                <field name="project_id"/>
                                <field name="partner_id"/>
                                <field name="partner_name"/>
                                <field name="company_id"/>
                            </group>
                        </group>
                        <group>
                            <group string="责任金额">
                                <field name="amount"/>
                                <field name="arrival_amount"/>
                                <field name="paid_amount"/>
                                <field name="deducted_amount"/>
                                <field name="self_funding_income_amount"/>
                                <field name="self_funding_refund_amount"/>
                            </group>
                            <group string="办理约束">
                                <field name="self_funding_balance_effect"/>
                                <field name="project_fund_status_effect"/>
                                <field name="contractor_responsibility_effect"/>
                            </group>
                        </group>
                        <group>
                            <group string="来源追溯">
                                <field name="source_model"/>
                                <field name="source_res_id"/>
                                <field name="source_document_no"/>
                                <field name="source_menu_hint"/>
                                <field name="source_fact_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sc_company_contractor_responsibility_fact_pivot" model="ir.ui.view">
            <field name="name">sc.company.contractor.responsibility.fact.pivot</field>
            <field name="model">sc.company.contractor.responsibility.fact</field>
            <field name="arch" type="xml">
                <pivot string="公司-承包人资金责任明细">
                    <field name="responsibility_type" type="row"/>
                    <field name="project_id" type="row"/>
                    <field name="amount" type="measure"/>
                    <field name="arrival_amount" type="measure"/>
                    <field name="paid_amount" type="measure"/>
                    <field name="deducted_amount" type="measure"/>
                    <field name="self_funding_income_amount" type="measure"/>
                    <field name="self_funding_refund_amount" type="measure"/>
                    <field name="contractor_responsibility_effect" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_sc_company_contractor_responsibility_fact" model="ir.actions.act_window">
            <field name="name">公司-承包人资金责任明细</field>
            <field name="res_model">sc.company.contractor.responsibility.fact</field>
            <field name="view_mode">tree,form,pivot</field>
            <field name="search_view_id" ref="view_sc_company_contractor_responsibility_fact_search"/>
            <field name="context">{'create': False, 'search_default_group_responsibility_type': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
        </record>
    </data>
</odoo>
