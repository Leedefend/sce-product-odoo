<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sc_material_stock_summary_search" model="ir.ui.view">
        <field name="name">sc.material.stock.summary.search</field>
        <field name="model">sc.material.stock.summary</field>
        <field name="arch" type="xml">
            <search string="库存统计表（新）">
                <field name="project_id"/>
                <field name="project_name"/>
                <field name="material_code"/>
                <field name="material_name"/>
                <field name="material_spec"/>
                <field name="partner_name"/>
                <field name="contract_no"/>
                <field name="warehouse_name"/>
                <filter string="有库存数量" name="has_stock_qty" domain="[('stock_qty', '!=', 0)]"/>
                <filter string="有库存金额" name="has_stock_amount" domain="[('stock_amount', '!=', 0)]"/>
                <filter string="有出库" name="has_out" domain="[('out_qty', '!=', 0)]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按材料" name="group_material" context="{'group_by': 'material_name'}"/>
                <filter string="按规格" name="group_spec" context="{'group_by': 'material_spec'}"/>
                <filter string="按单位" name="group_uom" context="{'group_by': 'material_uom'}"/>
                <filter string="按往来单位" name="group_partner" context="{'group_by': 'partner_name'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_material_stock_summary_tree" model="ir.ui.view">
        <field name="name">sc.material.stock.summary.tree</field>
        <field name="model">sc.material.stock.summary</field>
        <field name="arch" type="xml">
            <tree string="库存统计表（新）" create="0" edit="0" delete="0" default_order="material_name asc, project_name asc">
                <field name="project_name" string="项目"/>
                <field name="material_code"/>
                <field name="material_name"/>
                <field name="material_spec"/>
                <field name="material_uom"/>
                <field name="partner_name" optional="show"/>
                <field name="contract_no" optional="hide"/>
                <field name="warehouse_name" optional="hide"/>
                <field name="in_qty" sum="入库数量合计"/>
                <field name="in_avg_price"/>
                <field name="in_amount" sum="入库金额合计"/>
                <field name="out_qty" sum="出库数量合计"/>
                <field name="out_avg_price"/>
                <field name="out_amount" sum="出库金额合计"/>
                <field name="profit_qty" sum="利润数量合计"/>
                <field name="price_diff"/>
                <field name="profit_amount" sum="利润金额合计"/>
                <field name="stock_qty" sum="库存数量合计"/>
                <field name="stock_avg_price"/>
                <field name="stock_amount" sum="库存金额合计"/>
                <field name="stock_in_line_count" sum="入库明细数合计"/>
                <field name="stock_out_line_count" sum="出库明细数合计"/>
                <field name="last_date"/>
                <field name="coverage_note" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_material_stock_summary_form" model="ir.ui.view">
        <field name="name">sc.material.stock.summary.form</field>
        <field name="model">sc.material.stock.summary</field>
        <field name="arch" type="xml">
            <form string="库存统计表（新）" create="0" edit="0" delete="0">
                <header>
                    <button name="action_open_stock_in_lines" type="object" string="入库来源" class="btn-primary" invisible="in_qty == 0 and in_amount == 0"/>
                    <button name="action_open_stock_out_lines" type="object" string="出库来源" class="btn-secondary" invisible="out_qty == 0 and out_amount == 0"/>
                    <button name="action_open_all_stock_lines" type="object" string="全部明细" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="project_name"/>
                            <field name="company_id"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="material_code"/>
                            <field name="material_name"/>
                            <field name="material_spec"/>
                            <field name="material_uom"/>
                        </group>
                    </group>
                    <group string="业务维度">
                        <group>
                            <field name="partner_name"/>
                            <field name="contract_no"/>
                            <field name="warehouse_name"/>
                        </group>
                        <group>
                            <field name="first_date"/>
                            <field name="last_date"/>
                            <field name="coverage_note"/>
                        </group>
                    </group>
                    <group string="入库">
                        <field name="in_qty"/>
                        <field name="in_avg_price"/>
                        <field name="in_amount"/>
                        <field name="stock_in_line_count"/>
                    </group>
                    <group string="出库">
                        <field name="out_qty"/>
                        <field name="out_avg_price"/>
                        <field name="out_amount"/>
                        <field name="stock_out_line_count"/>
                    </group>
                    <group string="利润">
                        <field name="profit_qty"/>
                        <field name="price_diff"/>
                        <field name="profit_amount"/>
                    </group>
                    <group string="库存">
                        <field name="stock_qty"/>
                        <field name="stock_avg_price"/>
                        <field name="stock_amount"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_material_stock_summary_pivot" model="ir.ui.view">
        <field name="name">sc.material.stock.summary.pivot</field>
        <field name="model">sc.material.stock.summary</field>
        <field name="arch" type="xml">
            <pivot string="库存统计表（新）">
                <field name="project_id" type="row"/>
                <field name="material_name" type="row"/>
                <field name="in_qty" type="measure"/>
                <field name="in_amount" type="measure"/>
                <field name="out_qty" type="measure"/>
                <field name="out_amount" type="measure"/>
                <field name="profit_qty" type="measure"/>
                <field name="profit_amount" type="measure"/>
                <field name="stock_qty" type="measure"/>
                <field name="stock_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_sc_material_stock_summary" model="ir.actions.act_window">
        <field name="name">库存统计表（新）</field>
        <field name="res_model">sc.material.stock.summary</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="smart_construction_core.view_sc_material_stock_summary_search"/>
        <field name="context">{'create': False, 'edit': False, 'delete': False, 'search_default_group_material': 1}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_business_initiator'),
            ref('smart_construction_core.group_sc_cap_material_read'),
            ref('smart_construction_core.group_sc_cap_material_user'),
            ref('smart_construction_core.group_sc_cap_material_manager'),
            ref('smart_construction_core.group_sc_cap_cost_read'),
            ref('smart_construction_core.group_sc_cap_cost_user'),
            ref('smart_construction_core.group_sc_cap_cost_manager')
        ])]"/>
    </record>
</odoo>
