<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_sc_comprehensive_cost_summary_search" model="ir.ui.view">
        <field name="name">sc.comprehensive.cost.summary.search</field>
        <field name="model">sc.comprehensive.cost.summary</field>
        <field name="arch" type="xml">
            <search string="成本统计表（综合）">
                <field name="project_name"/>
                <filter string="有收入" name="has_income" domain="[('receipt_amount', '!=', 0)]"/>
                <filter string="有成本" name="has_cost" domain="[('total_cost_amount', '!=', 0)]"/>
                <filter string="有材料成本" name="has_material_cost" domain="[('material_cost_amount', '!=', 0)]"/>
                <filter string="有费用成本" name="has_expense_cost" domain="[('expense_cost_amount', '!=', 0)]"/>
                <filter string="有未付款" name="has_payable_unpaid" domain="[('payable_unpaid_amount', '!=', 0)]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_name'}"/>
                <filter string="按公司" name="group_company" context="{'group_by': 'company_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_comprehensive_cost_summary_tree" model="ir.ui.view">
        <field name="name">sc.comprehensive.cost.summary.tree</field>
        <field name="model">sc.comprehensive.cost.summary</field>
        <field name="arch" type="xml">
            <tree string="成本统计表（综合）" create="0" edit="0" delete="0">
                <field name="project_name"/>
                <field name="project_id" optional="hide"/>
                <field name="income_contract_amount" sum="收入合同金额合计"/>
                <field name="receipt_amount" sum="已收款合计"/>
                <field name="output_invoice_amount" sum="已开票合计"/>
                <field name="receivable_unpaid_amount" sum="未收款合计"/>
                <field name="payable_contract_amount" sum="应付合同金额合计"/>
                <field name="supplier_contract_amount" sum="供应商合同金额合计"/>
                <field name="material_cost_amount" sum="材料成本合计"/>
                <field name="labor_cost_amount" sum="劳务/分包成本合计"/>
                <field name="lease_cost_amount" sum="租赁/机械成本合计"/>
                <field name="expense_cost_amount" sum="费用成本合计"/>
                <field name="salary_cost_amount" sum="工资成本合计"/>
                <field name="input_invoice_amount" sum="成本发票金额合计"/>
                <field name="paid_amount" sum="已付款合计"/>
                <field name="payable_unpaid_amount" sum="未付款合计"/>
                <field name="total_cost_amount" sum="成本合计"/>
                <field name="profit_amount" sum="利润额合计"/>
                <field name="profit_rate"/>
                <field name="source_line_count" sum="来源明细数合计"/>
                <field name="material_line_count" sum="材料明细数合计"/>
                <field name="expense_line_count" sum="费用单数合计"/>
                <field name="salary_line_count" sum="工资单数合计"/>
                <field name="coverage_note" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_comprehensive_cost_summary_form" model="ir.ui.view">
        <field name="name">sc.comprehensive.cost.summary.form</field>
        <field name="model">sc.comprehensive.cost.summary</field>
        <field name="arch" type="xml">
            <form string="成本统计表（综合）" create="0" edit="0" delete="0">
                <header>
                    <button name="action_open_income_contracts" type="object" string="收入合同" class="btn-primary" invisible="income_contract_amount == 0"/>
                    <button name="action_open_receipts" type="object" string="收款登记" class="btn-secondary" invisible="receipt_amount == 0"/>
                    <button name="action_open_output_invoices" type="object" string="销项发票" class="btn-secondary" invisible="output_invoice_amount == 0"/>
                    <button name="action_open_payable_contracts" type="object" string="应付合同" class="btn-secondary" invisible="payable_contract_amount == 0"/>
                    <button name="action_open_supplier_contracts" type="object" string="供应商合同" class="btn-secondary" invisible="supplier_contract_amount == 0"/>
                    <button name="action_open_material_costs" type="object" string="材料成本" class="btn-secondary" invisible="material_cost_amount == 0"/>
                    <button name="action_open_labor_costs" type="object" string="劳务分包" class="btn-secondary" invisible="labor_cost_amount == 0"/>
                    <button name="action_open_lease_costs" type="object" string="租赁机械" class="btn-secondary" invisible="lease_cost_amount == 0"/>
                    <button name="action_open_expenses" type="object" string="费用报销" class="btn-secondary" invisible="expense_cost_amount == 0"/>
                    <button name="action_open_salary" type="object" string="工资登记" class="btn-secondary" invisible="salary_cost_amount == 0"/>
                    <button name="action_open_input_invoices" type="object" string="进项发票" class="btn-secondary" invisible="input_invoice_amount == 0"/>
                    <button name="action_open_payments" type="object" string="付款执行" class="btn-secondary" invisible="paid_amount == 0"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="project_name"/>
                            <field name="project_id"/>
                            <field name="company_id"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="profit_amount"/>
                            <field name="profit_rate"/>
                            <field name="coverage_note"/>
                        </group>
                    </group>
                    <group string="收入">
                        <field name="income_contract_amount"/>
                        <field name="receipt_amount"/>
                        <field name="output_invoice_amount"/>
                        <field name="receivable_unpaid_amount"/>
                    </group>
                    <group string="成本">
                        <field name="payable_contract_amount"/>
                        <field name="supplier_contract_amount"/>
                        <field name="material_cost_amount"/>
                        <field name="labor_cost_amount"/>
                        <field name="lease_cost_amount"/>
                        <field name="expense_cost_amount"/>
                        <field name="salary_cost_amount"/>
                        <field name="total_cost_amount"/>
                    </group>
                    <group string="付款与发票">
                        <field name="input_invoice_amount"/>
                        <field name="paid_amount"/>
                        <field name="payable_unpaid_amount"/>
                    </group>
                    <group string="来源数量">
                        <field name="source_line_count"/>
                        <field name="material_line_count"/>
                        <field name="expense_line_count"/>
                        <field name="salary_line_count"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_comprehensive_cost_summary_pivot" model="ir.ui.view">
        <field name="name">sc.comprehensive.cost.summary.pivot</field>
        <field name="model">sc.comprehensive.cost.summary</field>
        <field name="arch" type="xml">
            <pivot string="成本统计表（综合）">
                <field name="project_name" type="row"/>
                <field name="receipt_amount" type="measure"/>
                <field name="material_cost_amount" type="measure"/>
                <field name="expense_cost_amount" type="measure"/>
                <field name="salary_cost_amount" type="measure"/>
                <field name="total_cost_amount" type="measure"/>
                <field name="profit_amount" type="measure"/>
                <field name="paid_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_sc_comprehensive_cost_summary" model="ir.actions.act_window">
        <field name="name">成本统计表（综合）</field>
        <field name="res_model">sc.comprehensive.cost.summary</field>
        <field name="view_mode">tree,form,pivot,graph</field>
        <field name="search_view_id" ref="smart_construction_core.view_sc_comprehensive_cost_summary_search"/>
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_business_initiator'),
            ref('smart_construction_core.group_sc_cap_finance_read'),
            ref('smart_construction_core.group_sc_cap_finance_user'),
            ref('smart_construction_core.group_sc_cap_finance_manager'),
            ref('smart_construction_core.group_sc_cap_cost_read'),
            ref('smart_construction_core.group_sc_cap_cost_user'),
            ref('smart_construction_core.group_sc_cap_cost_manager'),
            ref('smart_construction_core.group_sc_cap_contract_read'),
            ref('smart_construction_core.group_sc_cap_contract_user'),
            ref('smart_construction_core.group_sc_cap_contract_manager')
        ])]"/>
    </record>
</odoo>
