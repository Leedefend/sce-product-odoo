<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_ar_ap_company_summary_search" model="ir.ui.view">
            <field name="name">sc.ar.ap.company.summary.search</field>
            <field name="model">sc.ar.ap.company.summary</field>
            <field name="arch" type="xml">
                <search string="应收应付报表">
                    <field name="project_name"/>
                    <field name="payable_pricing_method_text"/>
                    <filter string="有未收款" name="has_receivable_unpaid" domain="[('receivable_unpaid_amount', '!=', 0)]"/>
                    <filter string="有已开票未收款" name="has_invoiced_unreceived" domain="[('invoiced_unreceived_amount', '!=', 0)]"/>
                    <filter string="有应付合同" name="has_payable_contract" domain="[('payable_contract_amount', '!=', 0)]"/>
                    <filter string="有供应商发票" name="has_input_invoice" domain="[('input_invoice_amount', '!=', 0)]"/>
                    <filter string="有未付款" name="has_payable_unpaid" domain="[('payable_unpaid_amount', '!=', 0)]"/>
                    <filter string="有付款超票" name="has_paid_uninvoiced" domain="[('paid_uninvoiced_amount', '!=', 0)]"/>
                    <filter string="有抵扣税额" name="has_deduction_tax" domain="[('deduction_tax_amount', '!=', 0)]"/>
                    <filter string="有附加税" name="has_surcharge" domain="['|', '|', ('output_surcharge_amount', '!=', 0), ('input_surcharge_amount', '!=', 0), ('deduction_surcharge_amount', '!=', 0)]"/>
                    <filter string="有自筹未退" name="has_self_funding_unreturned" domain="[('self_funding_unreturned_amount', '!=', 0)]"/>
                    <filter string="实际可用余额为负" name="negative_actual_available" domain="[('actual_available_balance', '&lt;', 0)]"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_name'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_ar_ap_company_summary_tree" model="ir.ui.view">
            <field name="name">sc.ar.ap.company.summary.tree</field>
            <field name="model">sc.ar.ap.company.summary</field>
            <field name="arch" type="xml">
                <tree string="应收应付报表" create="0" edit="0" delete="0" default_order="project_name">
                    <field name="project_name"/>
                    <field name="project_id" optional="hide"/>
                    <field name="partner_count" sum="往来单位数合计"/>
                    <field name="income_contract_amount" sum="收入合同金额合计"/>
                    <field name="output_invoice_amount" sum="已开票合计"/>
                    <field name="receipt_amount" sum="已收款合计"/>
                    <field name="receivable_unpaid_amount" sum="未收款合计"/>
                    <field name="invoiced_unreceived_amount" sum="已开票未收款合计"/>
                    <field name="received_uninvoiced_amount" sum="已收款未开票合计"/>
                    <field name="payable_contract_amount" sum="应付合同金额合计"/>
                    <field name="payable_pricing_method_text"/>
                    <field name="input_invoice_amount" sum="供应商发票合计"/>
                    <field name="paid_amount" sum="已付款合计"/>
                    <field name="payable_unpaid_amount" sum="未付款合计"/>
                    <field name="paid_uninvoiced_amount" sum="付款超票合计"/>
                    <field name="output_tax_amount" sum="销项税额合计"/>
                    <field name="input_tax_amount" sum="进项税额合计"/>
                    <field name="deduction_tax_amount" sum="抵扣税额合计"/>
                    <field name="tax_deduction_rate"/>
                    <field name="output_surcharge_amount" sum="销项附加税合计"/>
                    <field name="input_surcharge_amount" sum="进项附加税合计"/>
                    <field name="deduction_surcharge_amount" sum="抵扣附加税合计"/>
                    <field name="self_funding_income_amount" sum="自筹收入合计"/>
                    <field name="self_funding_refund_amount" sum="自筹退回合计"/>
                    <field name="self_funding_unreturned_amount" sum="自筹未退合计"/>
                    <field name="actual_available_balance" sum="实际可用余额合计"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_ar_ap_company_summary_form" model="ir.ui.view">
            <field name="name">sc.ar.ap.company.summary.form</field>
            <field name="model">sc.ar.ap.company.summary</field>
            <field name="arch" type="xml">
                <form string="应收应付报表" create="0" edit="0" delete="0">
                    <header>
                        <button name="action_open_project_partner_rows" type="object" string="往来单位明细" class="btn-primary"/>
                        <button name="action_open_income_contracts" type="object" string="收入合同" class="btn-secondary"/>
                        <button name="action_open_expense_contracts" type="object" string="支出合同" class="btn-secondary"/>
                        <button name="action_open_receipts" type="object" string="收款登记" class="btn-secondary"/>
                        <button name="action_open_invoices" type="object" string="发票登记" class="btn-secondary"/>
                        <button name="action_open_payments" type="object" string="付款台账" class="btn-secondary"/>
                        <button name="action_open_finance_facts" type="object" string="资金事实" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="项目">
                                <field name="project_name"/>
                                <field name="project_id"/>
                                <field name="partner_count"/>
                                <field name="payable_pricing_method_text"/>
                            </group>
                            <group string="实际可用">
                                <field name="actual_available_balance"/>
                                <field name="tax_deduction_rate"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="应收">
                                <group>
                                    <field name="income_contract_amount"/>
                                    <field name="output_invoice_amount"/>
                                    <field name="receipt_amount"/>
                                    <field name="receivable_unpaid_amount"/>
                                    <field name="invoiced_unreceived_amount"/>
                                    <field name="received_uninvoiced_amount"/>
                                </group>
                            </page>
                            <page string="应付">
                                <group>
                                    <field name="payable_contract_amount"/>
                                    <field name="input_invoice_amount"/>
                                    <field name="paid_amount"/>
                                    <field name="payable_unpaid_amount"/>
                                    <field name="paid_uninvoiced_amount"/>
                                </group>
                            </page>
                            <page string="税费与自筹">
                                <group>
                                    <field name="output_tax_amount"/>
                                    <field name="input_tax_amount"/>
                                    <field name="deduction_tax_amount"/>
                                    <field name="output_surcharge_amount"/>
                                    <field name="input_surcharge_amount"/>
                                    <field name="deduction_surcharge_amount"/>
                                    <field name="self_funding_income_amount"/>
                                    <field name="self_funding_refund_amount"/>
                                    <field name="self_funding_unreturned_amount"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sc_ar_ap_company_summary_pivot" model="ir.ui.view">
            <field name="name">sc.ar.ap.company.summary.pivot</field>
            <field name="model">sc.ar.ap.company.summary</field>
            <field name="arch" type="xml">
                <pivot string="应收应付报表">
                    <field name="project_name" type="row"/>
                    <field name="income_contract_amount" type="measure"/>
                    <field name="output_invoice_amount" type="measure"/>
                    <field name="receipt_amount" type="measure"/>
                    <field name="receivable_unpaid_amount" type="measure"/>
                    <field name="invoiced_unreceived_amount" type="measure"/>
                    <field name="received_uninvoiced_amount" type="measure"/>
                    <field name="payable_contract_amount" type="measure"/>
                    <field name="input_invoice_amount" type="measure"/>
                    <field name="paid_amount" type="measure"/>
                    <field name="payable_unpaid_amount" type="measure"/>
                    <field name="paid_uninvoiced_amount" type="measure"/>
                    <field name="output_tax_amount" type="measure"/>
                    <field name="input_tax_amount" type="measure"/>
                    <field name="deduction_tax_amount" type="measure"/>
                    <field name="output_surcharge_amount" type="measure"/>
                    <field name="input_surcharge_amount" type="measure"/>
                    <field name="deduction_surcharge_amount" type="measure"/>
                    <field name="self_funding_income_amount" type="measure"/>
                    <field name="self_funding_refund_amount" type="measure"/>
                    <field name="self_funding_unreturned_amount" type="measure"/>
                    <field name="actual_available_balance" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="view_sc_ar_ap_company_summary_graph" model="ir.ui.view">
            <field name="name">sc.ar.ap.company.summary.graph</field>
            <field name="model">sc.ar.ap.company.summary</field>
            <field name="arch" type="xml">
                <graph string="应收应付对比" type="bar" stacked="True">
                    <field name="project_name" type="row"/>
                    <field name="income_contract_amount" type="measure"/>
                    <field name="receipt_amount" type="measure"/>
                    <field name="payable_contract_amount" type="measure"/>
                    <field name="input_invoice_amount" type="measure"/>
                    <field name="paid_amount" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="action_sc_ar_ap_company_summary" model="ir.actions.act_window">
            <field name="name">应收应付报表</field>
            <field name="res_model">sc.ar.ap.company.summary</field>
            <field name="view_mode">tree,form,pivot,graph</field>
            <field name="search_view_id" ref="view_sc_ar_ap_company_summary_search"/>
            <field name="context">{'create': False}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_business_initiator')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_manager')),
                                           (4, ref('smart_construction_core.group_sc_cap_contract_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_contract_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_contract_manager'))]"/>
        </record>

        <menuitem id="menu_sc_ar_ap_company_summary"
                  name="应收应付报表"
                  parent="smart_construction_core.menu_sc_data_center"
                  action="action_sc_ar_ap_company_summary"
                  sequence="35"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager,smart_construction_core.group_sc_cap_contract_read,smart_construction_core.group_sc_cap_contract_user,smart_construction_core.group_sc_cap_contract_manager"/>
    </data>
</odoo>
