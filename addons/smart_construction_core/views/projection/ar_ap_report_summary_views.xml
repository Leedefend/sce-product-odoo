<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sc_ar_ap_report_summary_search" model="ir.ui.view">
            <field name="name">sc.ar.ap.report.summary.search</field>
            <field name="model">sc.ar.ap.report.summary</field>
            <field name="arch" type="xml">
                <search string="应收应付报表">
                    <field name="project_name"/>
                    <field name="project_id"/>
                    <filter string="有应收" name="has_receivable" domain="[('income_contract_amount', '!=', 0)]"/>
                    <filter string="有应付" name="has_payable" domain="[('payable_contract_amount', '!=', 0)]"/>
                </search>
            </field>
        </record>

        <record id="view_sc_ar_ap_report_summary_tree" model="ir.ui.view">
            <field name="name">sc.ar.ap.report.summary.tree</field>
            <field name="model">sc.ar.ap.report.summary</field>
            <field name="arch" type="xml">
                <tree string="应收应付报表" create="0" edit="0" delete="0">
                    <field name="project_name"/>
                    <field name="income_contract_amount" sum="施工合同价合计"/>
                    <field name="receipt_amount" sum="已收款合计"/>
                    <field name="output_invoice_amount" sum="已开票合计"/>
                    <field name="received_uninvoiced_amount" sum="已收款未开票合计"/>
                    <field name="invoiced_unreceived_amount" sum="已开票未收款合计"/>
                    <field name="payable_contract_amount" sum="供货合同价合计"/>
                    <field name="paid_amount" sum="已付款合计"/>
                    <field name="input_invoice_amount" sum="应付已开票合计"/>
                    <field name="payable_unpaid_amount" sum="开票未付款合计"/>
                    <field name="paid_uninvoiced_amount" sum="付款未开票合计"/>
                    <field name="output_tax_amount" sum="开票登记税额合计"/>
                    <field name="input_tax_amount" sum="进项上报税额合计"/>
                    <field name="deduction_tax_amount" sum="抵扣总额合计"/>
                    <field name="tax_burden_rate" optional="show"/>
                    <field name="output_surcharge_amount" sum="销项附加税额合计"/>
                    <field name="input_surcharge_amount" sum="进项附加税额合计"/>
                    <button name="action_open_project_partner_rows" type="object" string="往来单位明细" class="btn-primary"/>
                    <button name="action_open_income_contracts" type="object" string="收入合同" class="btn-secondary"/>
                    <button name="action_open_expense_contracts" type="object" string="支出合同" class="btn-secondary"/>
                    <button name="action_open_receipts" type="object" string="收款登记" class="btn-secondary"/>
                    <button name="action_open_invoices" type="object" string="发票登记" class="btn-secondary"/>
                    <button name="action_open_payments" type="object" string="付款台账" class="btn-secondary"/>
                    <button name="action_open_finance_facts" type="object" string="资金事实" class="btn-secondary"/>
                    <field name="coverage_note" optional="hide"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_ar_ap_report_summary_pivot" model="ir.ui.view">
            <field name="name">sc.ar.ap.report.summary.pivot</field>
            <field name="model">sc.ar.ap.report.summary</field>
            <field name="arch" type="xml">
                <pivot string="应收应付报表">
                    <field name="project_name" type="row"/>
                    <field name="income_contract_amount" type="measure"/>
                    <field name="receipt_amount" type="measure"/>
                    <field name="output_invoice_amount" type="measure"/>
                    <field name="payable_contract_amount" type="measure"/>
                    <field name="paid_amount" type="measure"/>
                    <field name="input_invoice_amount" type="measure"/>
                    <field name="output_tax_amount" type="measure"/>
                    <field name="input_tax_amount" type="measure"/>
                    <field name="deduction_tax_amount" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_sc_ar_ap_report_summary" model="ir.actions.act_window">
            <field name="name">应收应付报表</field>
            <field name="res_model">sc.ar.ap.report.summary</field>
            <field name="view_mode">tree,pivot</field>
            <field name="search_view_id" ref="view_sc_ar_ap_report_summary_search"/>
        </record>
    </data>
</odoo>
