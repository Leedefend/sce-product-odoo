<odoo>
    <data>
        <record id="view_sc_fund_daily_summary_search" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.search</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <search string="企业资金日报汇总">
                    <field name="document_date" />
                    <field name="business_entity_id" />
                    <field name="business_entity_name" />
                    <filter string="有差异" name="has_difference" domain="[('bank_system_difference', '!=', 0)]" />
                    <filter string="按日期" name="group_document_date" context="{'group_by': 'document_date'}" />
                    <filter string="按业务主体" name="group_business_entity" context="{'group_by': 'business_entity_id'}" />
                </search>
            </field>
        </record>
        <record id="view_sc_fund_daily_summary_tree" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.tree</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <tree string="企业资金日报汇总" create="0" edit="0" delete="0" default_order="document_date desc, business_entity_id">
                    <field name="document_date" />
                    <field name="business_entity_id" />
                    <field name="line_count" sum="日报数" />
                    <field name="current_account_balance" sum="账面余额合计" />
                    <field name="current_bank_balance" sum="银行余额合计" />
                    <field name="bank_system_difference" sum="账实差异合计" />
                </tree>
            </field>
        </record>
        <record id="view_sc_fund_daily_summary_form" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.form</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <form string="企业资金日报汇总" create="0" edit="0" delete="0">
                    <header>
                        <button name="action_open_snapshot_facts" type="object" string="查看企业资金日报" class="btn-primary" invisible="line_count == 0" />
                    </header>
                    <sheet>
                        <group>
                            <group string="日期与业务主体">
                                <field name="document_date" />
                                <field name="business_entity_id" />
                                <field name="company_id" />
                                <field name="line_count" />
                            </group>
                        </group>
                        <group string="余额">
                            <group>
                                <field name="current_account_balance" />
                                <field name="current_bank_balance" />
                                <field name="bank_system_difference" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_sc_fund_daily_summary_pivot" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.pivot</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <pivot string="企业资金日报汇总">
                    <field name="document_date" type="row" />
                    <field name="business_entity_id" type="row" />
                    <field name="current_account_balance" type="measure" />
                    <field name="current_bank_balance" type="measure" />
                    <field name="bank_system_difference" type="measure" />
                    <field name="line_count" type="measure" />
                </pivot>
            </field>
        </record>
        <record id="view_sc_fund_daily_summary_graph" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.graph</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <graph string="企业资金日报趋势" type="bar" stacked="True">
                    <field name="document_date" type="row" />
                    <field name="current_account_balance" type="measure" />
                    <field name="current_bank_balance" type="measure" />
                </graph>
            </field>
        </record>
        <record id="action_sc_fund_daily_summary" model="ir.actions.act_window">
            <field name="name">企业资金日报汇总</field>
            <field name="res_model">sc.fund.daily.summary</field>
            <field name="view_mode">tree,form,pivot,graph</field>
            <field name="search_view_id" ref="view_sc_fund_daily_summary_search" />
            <field name="context">{'create': False, 'search_default_group_business_entity': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),                                            (4, ref('smart_construction_core.group_sc_cap_finance_user')),                                            (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]" />
        </record>
        <menuitem id="menu_sc_fund_daily_summary" name="企业资金日报汇总" parent="smart_construction_core.menu_sc_finance_center" action="action_sc_fund_daily_summary" sequence="35" groups="smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager" />
    </data>
</odoo>
