<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_finance_business_fact_search" model="ir.ui.view">
            <field name="name">sc.finance.business.fact.search</field>
            <field name="model">sc.finance.business.fact</field>
            <field name="arch" type="xml">
                <search string="项目收付款来源明细">
                    <field name="source_record_name"/>
                    <field name="source_document_no"/>
                    <field name="project_id"/>
                    <field name="partner_name"/>
                    <filter string="到款确认" name="arrival_settlement" domain="[('business_domain', '=', 'arrival_settlement')]"/>
                    <filter string="扣款清分" name="deduction_clearing" domain="[('business_domain', '=', 'deduction_clearing')]"/>
                    <filter string="抵扣登记" name="tax_deduction" domain="[('business_domain', '=', 'tax_deduction')]"/>
                    <filter string="自筹资金" name="self_funding" domain="[('business_domain', '=', 'self_funding')]"/>
                    <filter string="保证金" name="guarantee_deposit" domain="[('business_domain', '=', 'guarantee_deposit')]"/>
                    <filter string="正式余额" name="canonical" domain="[('balance_policy', '=', 'canonical')]"/>
                    <filter string="可见参考" name="visible_reference" domain="[('balance_policy', '=', 'visible_reference')]"/>
                    <filter string="按业务域" name="group_business_domain" context="{'group_by': 'business_domain'}"/>
                    <filter string="按事实类型" name="group_fact_type" context="{'group_by': 'fact_type'}"/>
                    <filter string="按余额策略" name="group_balance_policy" context="{'group_by': 'balance_policy'}"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_finance_business_fact_tree" model="ir.ui.view">
            <field name="name">sc.finance.business.fact.tree</field>
            <field name="model">sc.finance.business.fact</field>
            <field name="arch" type="xml">
                <tree string="项目收付款来源明细" create="0" edit="0" delete="0" default_order="document_date desc, id desc">
                    <field name="document_date"/>
                    <field name="business_domain"/>
                    <field name="fact_type"/>
                    <field name="balance_policy"/>
                    <field name="project_id"/>
                    <field name="partner_name"/>
                    <field name="amount" sum="事实金额合计"/>
                    <field name="balance_effect" sum="余额影响合计"/>
                    <field name="cash_in_amount" sum="流入合计"/>
                    <field name="cash_out_amount" sum="流出合计"/>
                    <field name="deduction_amount" sum="扣款合计"/>
                    <field name="paid_amount" sum="拨付合计"/>
                    <field name="tax_amount" sum="税额合计"/>
                    <field name="source_model"/>
                    <field name="source_record_name"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_finance_business_fact_form" model="ir.ui.view">
            <field name="name">sc.finance.business.fact.form</field>
            <field name="model">sc.finance.business.fact</field>
            <field name="arch" type="xml">
                <form string="项目收付款来源明细" create="0" edit="0" delete="0">
                    <header>
                        <button name="action_open_source_record" type="object" string="打开来源单据" class="btn-primary"/>
                        <button name="action_open_business_entry" type="object" string="进入同类办理" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="收付款分类">
                                <field name="display_name"/>
                                <field name="business_domain"/>
                                <field name="fact_type"/>
                                <field name="balance_policy"/>
                                <field name="classification_reason"/>
                            </group>
                            <group string="金额">
                                <field name="document_date"/>
                                <field name="amount"/>
                                <field name="balance_effect"/>
                                <field name="cash_in_amount"/>
                                <field name="cash_out_amount"/>
                                <field name="deduction_amount"/>
                                <field name="paid_amount"/>
                                <field name="tax_amount"/>
                            </group>
                        </group>
                        <group>
                            <group string="业务对象">
                                <field name="project_id"/>
                                <field name="partner_id"/>
                                <field name="partner_name"/>
                                <field name="company_id"/>
                                <field name="state"/>
                            </group>
                            <group string="来源追溯">
                                <field name="source_model"/>
                                <field name="source_res_id"/>
                                <field name="source_record_name"/>
                                <field name="source_document_no"/>
                                <field name="source_menu_hint"/>
                            </group>
                        </group>
                        <group>
                            <field name="source_note"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sc_finance_business_fact_pivot" model="ir.ui.view">
            <field name="name">sc.finance.business.fact.pivot</field>
            <field name="model">sc.finance.business.fact</field>
            <field name="arch" type="xml">
                <pivot string="项目收付款来源明细">
                    <field name="business_domain" type="row"/>
                    <field name="fact_type" type="row"/>
                    <field name="balance_policy" type="col"/>
                    <field name="amount" type="measure"/>
                    <field name="balance_effect" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_sc_finance_business_fact" model="ir.actions.act_window">
            <field name="name">项目收付款来源明细</field>
            <field name="res_model">sc.finance.business.fact</field>
            <field name="view_mode">tree,form,pivot</field>
            <field name="search_view_id" ref="view_sc_finance_business_fact_search"/>
            <field name="context">{'create': False, 'search_default_group_business_domain': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
        </record>
    </data>
</odoo>
