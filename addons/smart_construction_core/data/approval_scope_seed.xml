<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="approval_scope_executive" model="sc.approval.scope">
            <field name="sequence">1</field>
            <field name="name">管理层/总经理终审</field>
            <field name="scope_key">executive</field>
            <field name="note">用于金额较大或关键业务的管理层终审；不包含平台系统管理员权限。</field>
        </record>
        <record id="approval_scope_business_admin" model="sc.approval.scope">
            <field name="sequence">2</field>
            <field name="name">业务配置管理员</field>
            <field name="scope_key">business_admin</field>
            <field name="note">用于业务配置、主数据规则类审批。</field>
        </record>
        <record id="approval_scope_operation_user" model="sc.approval.scope">
            <field name="sequence">3</field>
            <field name="name">经营审核人</field>
            <field name="scope_key">operation_user</field>
            <field name="note">用于合同、经营口径和客户供应商相关业务审核。</field>
        </record>
        <record id="approval_scope_partner_manager" model="sc.approval.scope">
            <field name="sequence">4</field>
            <field name="name">客商资料审核人</field>
            <field name="scope_key">partner_manager</field>
            <field name="note">用于客户、供应商、往来单位主数据维护审核。</field>
        </record>
        <record id="approval_scope_project_user" model="sc.approval.scope">
            <field name="sequence">5</field>
            <field name="name">项目部/工程部经办</field>
            <field name="scope_key">project_user</field>
            <field name="note">用于项目或工程资料经办确认。</field>
        </record>
        <record id="approval_scope_project_manager" model="sc.approval.scope">
            <field name="sequence">10</field>
            <field name="name">项目负责人</field>
            <field name="scope_key">project_manager</field>
            <field name="note">可审批项目相关业务。</field>
        </record>
        <record id="approval_scope_material_manager" model="sc.approval.scope">
            <field name="sequence">20</field>
            <field name="name">物资审核人</field>
            <field name="scope_key">material_manager</field>
            <field name="note">可审批物资计划等物资中心业务。</field>
        </record>
        <record id="approval_scope_purchase_manager" model="sc.approval.scope">
            <field name="sequence">30</field>
            <field name="name">采购审核人</field>
            <field name="scope_key">purchase_manager</field>
            <field name="note">可审批采购订单等采购业务；历史合同事实仅作只读承载。</field>
        </record>
        <record id="approval_scope_finance_manager" model="sc.approval.scope">
            <field name="sequence">40</field>
            <field name="name">财务审核人</field>
            <field name="scope_key">finance_manager</field>
            <field name="note">可审批付款申请、费用/保证金等财务业务。</field>
        </record>
        <record id="approval_scope_finance_user" model="sc.approval.scope">
            <field name="sequence">41</field>
            <field name="name">财务经办人</field>
            <field name="scope_key">finance_user</field>
            <field name="note">用于付款、收款、费用类单据的财务经办确认。</field>
        </record>
        <record id="approval_scope_temporary_finance" model="sc.approval.scope">
            <field name="sequence">42</field>
            <field name="name">受限财务</field>
            <field name="scope_key">temporary_finance</field>
            <field name="note">用于财务只读查看或受限参与，不作为默认终审。</field>
        </record>
        <record id="approval_scope_contract_manager" model="sc.approval.scope">
            <field name="sequence">50</field>
            <field name="name">合同审核人</field>
            <field name="scope_key">contract_manager</field>
            <field name="note">可审批项目合同、一般合同（公司）等合同业务。</field>
        </record>
        <record id="approval_scope_contract_user" model="sc.approval.scope">
            <field name="sequence">51</field>
            <field name="name">合同经办人</field>
            <field name="scope_key">contract_user</field>
            <field name="note">用于合同资料经办确认。</field>
        </record>
        <record id="approval_scope_cost_manager" model="sc.approval.scope">
            <field name="sequence">60</field>
            <field name="name">成控审核人</field>
            <field name="scope_key">cost_manager</field>
            <field name="note">可审批成控相关业务。</field>
        </record>
        <record id="approval_scope_cost_user" model="sc.approval.scope">
            <field name="sequence">61</field>
            <field name="name">成本经办人</field>
            <field name="scope_key">cost_user</field>
            <field name="note">用于成本资料经办确认。</field>
        </record>
        <record id="approval_scope_settlement_manager" model="sc.approval.scope">
            <field name="sequence">70</field>
            <field name="name">结算审核人</field>
            <field name="scope_key">settlement_manager</field>
            <field name="note">可审批结算单等结算业务。</field>
        </record>
        <record id="approval_scope_settlement_user" model="sc.approval.scope">
            <field name="sequence">71</field>
            <field name="name">结算经办人</field>
            <field name="scope_key">settlement_user</field>
            <field name="note">用于结算资料经办确认。</field>
        </record>
    </data>
</odoo>
