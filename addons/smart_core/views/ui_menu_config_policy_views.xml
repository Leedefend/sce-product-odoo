<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_ui_menu_config_policy_search" model="ir.ui.view">
    <field name="name">ui.menu.config.policy.search</field>
    <field name="model">ui.menu.config.policy</field>
    <field name="arch" type="xml">
      <search string="菜单配置">
        <field name="menu_id"/>
        <field name="target_parent_menu_id"/>
        <field name="custom_label"/>
        <field name="role_group_ids"/>
        <filter string="显示" name="visible" domain="[('visible', '=', True)]"/>
        <filter string="隐藏" name="hidden" domain="[('visible', '=', False)]"/>
        <filter string="已改名" name="renamed" domain="[('custom_label', '!=', False)]"/>
        <filter string="已排序" name="reordered" domain="[('sequence_override', '!=', 0)]"/>
        <filter string="已调整分组" name="moved" domain="[('target_parent_menu_id', '!=', False)]"/>
        <filter string="按菜单" name="group_menu" context="{'group_by': 'menu_id'}"/>
        <filter string="按目标分组" name="group_target_parent" context="{'group_by': 'target_parent_menu_id'}"/>
      </search>
    </field>
  </record>

  <record id="view_ui_menu_config_policy_tree" model="ir.ui.view">
    <field name="name">ui.menu.config.policy.tree</field>
    <field name="model">ui.menu.config.policy</field>
    <field name="arch" type="xml">
      <tree string="菜单配置" create="1" edit="1" delete="1" default_order="menu_id, id desc">
        <field name="menu_id" string="菜单"/>
        <field name="current_parent_menu_id" string="当前所属分组"/>
        <field name="target_parent_menu_id" string="调整到菜单分组"/>
        <field name="effect_summary" string="配置结果"/>
        <field name="scope_summary" string="适用范围"/>
        <field name="visible" string="显示菜单"/>
        <field name="active" string="启用"/>
      </tree>
    </field>
  </record>

  <record id="view_ui_menu_config_policy_form" model="ir.ui.view">
    <field name="name">ui.menu.config.policy.form</field>
    <field name="model">ui.menu.config.policy</field>
    <field name="arch" type="xml">
      <form string="菜单配置" create="1" edit="1" delete="1">
        <sheet>
          <div class="alert alert-info" role="alert">
            按三步配置：先选择要调整的菜单，再设置显示方式，最后选择可见业务角色。业务角色留空时，对当前公司所有用户生效；保存后刷新页面即可看到结果。
          </div>
          <group>
            <group string="第一步：选择要调整的菜单">
              <field name="company_id" readonly="1"/>
              <field name="menu_id" required="1" options="{'no_create': True, 'no_open': True}"/>
              <field name="original_label" readonly="1"/>
              <field name="current_parent_menu_id" readonly="1"/>
              <field name="current_parent_menu_complete_name" readonly="1"/>
              <field name="active"/>
            </group>
            <group string="第二步：调整显示方式">
              <field name="visible"/>
              <field name="target_parent_menu_id" placeholder="留空则保留当前分组" options="{'no_create': True, 'no_open': True}"/>
              <field name="target_parent_menu_complete_name" readonly="1"/>
              <field name="custom_label" placeholder="留空则使用原菜单名称"/>
              <field name="sequence_override" placeholder="留空或 0 则使用原顺序"/>
              <field name="effect_summary" readonly="1"/>
            </group>
          </group>
          <group string="第三步：选择对哪些业务角色生效">
            <field name="role_group_ids"
                   widget="many2many_tags"
                   options="{'no_create': True, 'no_open': True}"
                   placeholder="留空表示所有业务角色"/>
            <field name="scope_summary" readonly="1"/>
          </group>
          <group string="保存前确认">
            <field name="preview_summary" readonly="1" nolabel="1"/>
          </group>
          <group string="说明">
            <field name="note" nolabel="1" placeholder="可填写这条菜单调整的原因，例如：给合同管理员放到合同中心。"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_ui_menu_config_policy" model="ir.actions.act_window">
    <field name="name">菜单配置</field>
    <field name="res_model">ui.menu.config.policy</field>
    <field name="view_mode">tree,form</field>
    <field name="view_id" ref="smart_core.view_ui_menu_config_policy_tree"/>
    <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'tree', 'view_id': ref('smart_core.view_ui_menu_config_policy_tree')}), (0, 0, {'view_mode': 'form', 'view_id': ref('smart_core.view_ui_menu_config_policy_form')})]"/>
    <field name="search_view_id" ref="smart_core.view_ui_menu_config_policy_search"/>
    <field name="context">{'search_default_visible': 1}</field>
    <field name="groups_id" eval="[(6, 0, [
      ref('smart_core.group_smart_core_business_config_admin'),
      ref('smart_core.group_smart_core_admin')
    ])]"/>
  </record>
</odoo>
