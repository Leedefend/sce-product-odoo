<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!--
    Legacy compatibility groups.
    Boundary rule:
    - Keep only for backward compatibility.
    - Do NOT introduce new REQUIRED_GROUPS references to group_sc_* in new code.
    - Use group_smart_core_* canonical groups instead.
  -->
  <record id="group_sc_data_operator" model="res.groups">
    <field name="name">SC Data Operator (Legacy Compat)</field>
    <field name="category_id" ref="base.module_category_hidden"/>
    <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_smart_core_data_operator'))]"/>
  </record>

  <record id="group_sc_finance_approver" model="res.groups">
    <field name="name">SC Finance Approver (Legacy Compat)</field>
    <field name="category_id" ref="base.module_category_hidden"/>
    <field name="implied_ids" eval="[(4, ref('group_sc_data_operator')), (4, ref('group_smart_core_finance_approver'))]"/>
  </record>

  <record id="group_sc_scene_admin" model="res.groups">
    <field name="name">SC Scene Admin (Legacy Compat)</field>
    <field name="category_id" ref="base.module_category_hidden"/>
    <field name="implied_ids" eval="[(4, ref('group_smart_core_admin')), (4, ref('group_smart_core_scene_admin'))]"/>
  </record>
</odoo>
