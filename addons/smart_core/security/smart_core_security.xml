<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- 基础分组：后续可用于 API 访问策略/审计权限控制 -->
  <record id="group_smart_core_user" model="res.groups">
    <field name="name">Smart Core User</field>
    <field name="category_id" ref="base.module_category_hidden"/>
  </record>

  <record id="group_smart_core_business_config_admin" model="res.groups">
    <field name="name">Smart Core Business Config Admin</field>
    <field name="implied_ids" eval="[(4, ref('group_smart_core_user'))]"/>
    <field name="category_id" ref="base.module_category_hidden"/>
  </record>

  <record id="group_smart_core_admin" model="res.groups">
    <field name="name">Smart Core Admin</field>
    <field name="implied_ids" eval="[(4, ref('group_smart_core_user')), (4, ref('group_smart_core_business_config_admin'))]"/>
    <field name="category_id" ref="base.module_category_hidden"/>
  </record>

  <record id="group_smart_core_data_operator" model="res.groups">
    <field name="name">Smart Core Data Operator</field>
    <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    <field name="category_id" ref="base.module_category_hidden"/>
  </record>

  <record id="group_smart_core_tenant_payload_importer" model="res.groups">
    <field name="name">Tenant Payload Import Service</field>
    <field name="implied_ids" eval="[(4, ref('group_smart_core_data_operator'))]"/>
    <field name="category_id" ref="base.module_category_hidden"/>
  </record>

  <record id="rule_sc_tenant_payload_import_batch_company" model="ir.rule">
    <field name="name">Tenant payload import batch: operator owned</field>
    <field name="model_id" ref="model_sc_tenant_payload_import_batch"/>
    <field name="domain_force">[('operator_id', '=', user.id)]</field>
    <field name="groups" eval="[(4, ref('group_smart_core_tenant_payload_importer'))]"/>
  </record>

  <record id="rule_sc_tenant_payload_external_identity_company" model="ir.rule">
    <field name="name">Tenant payload external identity: allowed company</field>
    <field name="model_id" ref="model_sc_tenant_payload_external_identity"/>
    <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    <field name="groups" eval="[(4, ref('group_smart_core_tenant_payload_importer'))]"/>
  </record>

  <record id="group_smart_core_scene_admin" model="res.groups">
    <field name="name">Smart Core Scene Admin</field>
    <field name="implied_ids" eval="[(4, ref('group_smart_core_admin'))]"/>
    <field name="category_id" ref="base.module_category_hidden"/>
  </record>

  <record id="group_smart_core_finance_approver" model="res.groups">
    <field name="name">Smart Core Finance Approver</field>
    <field name="implied_ids" eval="[(4, ref('group_smart_core_data_operator'))]"/>
    <field name="category_id" ref="base.module_category_hidden"/>
  </record>

  <record id="rule_sc_user_view_preference_own" model="ir.rule">
    <field name="name">Smart Core User View Preference: own records</field>
    <field name="model_id" ref="model_sc_user_view_preference"/>
    <field name="domain_force">[('user_id', '=', user.id)]</field>
    <field name="groups" eval="[(4, ref('base.group_user'))]"/>
  </record>

  <record id="rule_ui_business_config_change_set_owner" model="ir.rule">
    <field name="name">Business config change set: owner and allowed company</field>
    <field name="model_id" ref="model_ui_business_config_change_set"/>
    <field name="domain_force">[('user_id', '=', user.id), ('company_id', 'in', company_ids)]</field>
    <field name="groups" eval="[(4, ref('group_smart_core_business_config_admin'))]"/>
  </record>

  <record id="rule_ui_business_config_change_set_item_owner" model="ir.rule">
    <field name="name">Business config change set item: owner and allowed company</field>
    <field name="model_id" ref="model_ui_business_config_change_set_item"/>
    <field name="domain_force">[('change_set_id.user_id', '=', user.id), ('change_set_id.company_id', 'in', company_ids)]</field>
    <field name="groups" eval="[(4, ref('group_smart_core_business_config_admin'))]"/>
  </record>

  <record id="rule_ui_business_config_mutation_audit_owner" model="ir.rule">
    <field name="name">Business config mutation audit: owner and allowed company</field>
    <field name="model_id" ref="model_ui_business_config_mutation_audit"/>
    <field name="domain_force">[('user_id', '=', user.id), ('company_id', 'in', company_ids)]</field>
    <field name="groups" eval="[(4, ref('group_smart_core_business_config_admin'))]"/>
  </record>
</odoo>
