      <field name="category">危大工程</field>
      <field name="subcategory">模板支撑体系</field>
      <field name="risk_level">critical</field>
      <field name="control_measure">方案审批、材料验收、搭设验收、沉降监测和旁站巡检。</field>
      <field name="group_attention">True</field>
      <field name="qualification_required">架子工持证上岗</field>
      <field name="bottom_line">True</field>
