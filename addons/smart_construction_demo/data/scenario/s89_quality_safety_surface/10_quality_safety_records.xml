<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <data noupdate="1">

    <record id="sc_demo_check_standard_089_quality" model="sc.check.standard">
      <field name="name">S89 主体结构质量检查标准</field>
      <field name="standard_type">quality</field>
      <field name="scope">project</field>
      <field name="project_id" ref="smart_construction_demo.sc_demo_project_001"/>
      <field name="default_rechecker_id" ref="base.user_admin"/>
      <field name="import_source">manual</field>
      <field name="effective_from">2025-08-01</field>
      <field name="applies_building_room">True</field>
      <field name="active">True</field>
    </record>

    <record id="sc_demo_check_standard_item_089_rebar" model="sc.check.standard.item">
      <field name="standard_id" ref="smart_construction_demo.sc_demo_check_standard_089_quality"/>
      <field name="sequence">10</field>
      <field name="name">钢筋保护层厚度</field>
      <field name="requirement">保护层厚度满足设计和规范允许偏差要求。</field>
      <field name="bottom_line">True</field>
      <field name="photo_required">True</field>
      <field name="control_type">main</field>
      <field name="acceptance_flow">supervisor</field>
      <field name="score_weight">40.0</field>
      <field name="tag">主体结构</field>
    </record>

    <record id="sc_demo_quality_issue_089_rebar" model="sc.quality.issue">
      <field name="name">S89 梁底钢筋保护层偏差</field>
      <field name="project_id" ref="smart_construction_demo.sc_demo_project_001"/>
      <field name="standard_id" ref="smart_construction_demo.sc_demo_check_standard_089_quality"/>
      <field name="standard_item_id" ref="smart_construction_demo.sc_demo_check_standard_item_089_rebar"/>
      <field name="issue_date">2025-08-06</field>
      <field name="source_channel">app</field>
      <field name="issue_category">quality</field>
      <field name="location">1# 楼三层 B 区梁底</field>
      <field name="building">1# 楼</field>
      <field name="room">三层 B 区</field>
      <field name="issue_level">important</field>
      <field name="responsible_party_id" ref="smart_construction_demo.sc_demo_partner_vendor_concrete"/>
      <field name="owner_id" ref="base.user_admin"/>
      <field name="rechecker_id" ref="base.user_admin"/>
      <field name="rectification_deadline">2025-08-09</field>
      <field name="description">抽检发现局部梁底钢筋保护层垫块缺失，需补设并复验。</field>
      <field name="state">submitted</field>
    </record>

    <record id="sc_demo_quality_rectification_089_rebar" model="sc.quality.rectification">
      <field name="issue_id" ref="smart_construction_demo.sc_demo_quality_issue_089_rebar"/>
      <field name="rectification_date">2025-08-07</field>
      <field name="source_channel">app</field>
      <field name="handler_id" ref="base.user_admin"/>
      <field name="result">已补设保护层垫块并复核钢筋定位。</field>
    </record>
  </data>

  <data noupdate="0">
    <function model="sc.quality.issue" name="action_request_recheck">
      <value model="sc.quality.issue" eval="obj([ref('smart_construction_demo.sc_demo_quality_issue_089_rebar')]).filtered(lambda issue: issue.state == 'rectifying').ids"/>
    </function>
  </data>

  <data noupdate="1">
    <record id="sc_demo_quality_recheck_089_rebar" model="sc.quality.recheck">
      <field name="issue_id" ref="smart_construction_demo.sc_demo_quality_issue_089_rebar"/>
      <field name="recheck_date">2025-08-08</field>
      <field name="source_channel">pc</field>
      <field name="recheck_user_id" ref="base.user_admin"/>
      <field name="result">passed</field>
      <field name="comment">复验通过，问题闭环。</field>
    </record>

    <record id="sc_demo_site_photo_batch_089_quality" model="sc.site.photo.batch">
      <field name="name">S89 质量整改复验照片</field>
      <field name="project_id" ref="smart_construction_demo.sc_demo_project_001"/>
      <field name="evidence_stage">recheck</field>
      <field name="quality_issue_id" ref="smart_construction_demo.sc_demo_quality_issue_089_rebar"/>
      <field name="quality_rectification_id" ref="smart_construction_demo.sc_demo_quality_rectification_089_rebar"/>
      <field name="quality_recheck_id" ref="smart_construction_demo.sc_demo_quality_recheck_089_rebar"/>
      <field name="batch_date">2025-08-08</field>
