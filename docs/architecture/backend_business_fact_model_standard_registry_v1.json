        "scripts/migration/history_expense_deposit_runtime_probe.py",
        "scripts/verify/formal_business_backfill_audit_probe.py",
        "scripts/verify/formal_projection_refresh_probe.py"
      ],
      "standard_exceptions": [],
      "solution_layer": "industry",
      "target_problem": "解决施工企业费用、保证金、扣款、还款等项目资金事实统一承载问题。",
      "promotion_policy": "资金单据底座可沉淀为 platform，但当前 claim_type 和税务/保证金语义属于 construction industry。"
    },
