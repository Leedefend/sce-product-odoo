{
  "schema": "backend_business_projection_registry_v1",
  "status": "draft architecture audit",
  "purpose": "Classify projection/read surfaces by implementation mode so SQL views, physical refresh tables, runtime facts, and controlled ledgers are not conflated.",
  "projections": [
    {
      "model": "sc.dashboard.cockpit.fact",
      "implementation_mode": "runtime_workbench_fact",
      "write_policy": "runtime producer writes by source_model/source_res_id uniqueness",
      "source_models": ["source_model/source_res_id"],
      "refresh_owner": "cockpit and business menu producers",
      "idempotency_key": "fact_type, source_model, source_res_id",
      "acceptance_probe": "model family coverage and dashboard runtime probes"
    },
    {
      "model": "sc.workbench.item",
      "implementation_mode": "runtime_workbench_fact",
      "write_policy": "runtime producer writes workbench/task visibility",
      "source_models": ["source_model/source_res_id"],
      "refresh_owner": "workbench producers",
      "idempotency_key": "source_model, source_res_id, entry_key",
      "acceptance_probe": "model family coverage and workbench runtime probes"
    },
    {
      "model": "sc.contract.recon.summary",
      "implementation_mode": "computed_runtime_summary",
      "write_policy": "computed fields read from contract, settlement, and payment facts",
      "source_models": ["construction.contract", "sc.settlement.order", "payment.request"],
      "refresh_owner": "Odoo computed fields",
      "idempotency_key": "contract_id",
      "acceptance_probe": "model family coverage"
    },
    {
      "model": "project.cost.ledger",
