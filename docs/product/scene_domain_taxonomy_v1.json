{
  "version": "v1",
  "max_domain_count": 25,
  "domains": [
    {
      "key": "project_execution",
      "label": "Project Execution",
      "description": "Project intake, list, ledger, and dashboard execution surfaces."
    },
    {
      "key": "finance_operations",
      "label": "Finance Operations",
      "description": "Payment, treasury, settlement, and operating finance surfaces."
    },
    {
      "key": "cost_control",
      "label": "Cost Control",
      "description": "Budget, BOQ, cost ledger, and profitability analysis surfaces."
    },
    {
      "key": "portal_governance",
      "label": "Portal Governance",
      "description": "Capability matrix, dashboard, and lifecycle governance surfaces."
    },
    {
      "key": "workspace_shell",
      "label": "Workspace Shell",
      "description": "Default workspace shell and smoke-default shells."
    },
    {
      "key": "data_foundation",
      "label": "Data Foundation",
      "description": "Dictionary and base metadata surfaces."
    },
    {
      "key": "contract_workspace",
      "label": "Contract Workspace",
      "description": "Contract center and contract workspace surfaces."
    },
    {
      "key": "procurement_supply",
      "label": "Procurement and Supply",
      "description": "Material, labor, equipment, and subcontract collaboration surfaces."
    },
    {
      "key": "site_quality_safety",
      "label": "Site Quality and Safety",
      "description": "Construction execution, quality issue, and safety issue surfaces."
    }
  ],
  "rules": [
    {
      "match_type": "exact",
      "pattern": "project.management",
      "domain": "project_execution"
    },
    {
      "match_type": "prefix",
      "pattern": "projects.",
      "domain": "project_execution"
    },
    {
      "match_type": "prefix",
      "pattern": "task.",
      "domain": "project_execution"
    },
    {
      "match_type": "prefix",
      "pattern": "risk.",
      "domain": "project_execution"
    },
    {
      "match_type": "prefix",
      "pattern": "finance.",
      "domain": "finance_operations"
    },
    {
      "match_type": "prefix",
      "pattern": "cost.",
      "domain": "cost_control"
    },
    {
      "match_type": "prefix",
      "pattern": "portal.",
      "domain": "portal_governance"
    },
    {
      "match_type": "prefix",
      "pattern": "data.",
      "domain": "data_foundation"
    },
    {
      "match_type": "prefix",
      "pattern": "contract.",
      "domain": "contract_workspace"
    },
    {
      "match_type": "prefix",
      "pattern": "contracts.",
      "domain": "contract_workspace"
    },
    {
      "match_type": "prefix",
      "pattern": "material.",
      "domain": "procurement_supply"
    },
    {
      "match_type": "prefix",
      "pattern": "labor.",
      "domain": "procurement_supply"
    },
    {
      "match_type": "prefix",
      "pattern": "equipment.",
      "domain": "procurement_supply"
    },
    {
      "match_type": "prefix",
      "pattern": "subcontract.",
      "domain": "procurement_supply"
    },
    {
      "match_type": "prefix",
      "pattern": "construction.",
      "domain": "site_quality_safety"
    },
    {
      "match_type": "prefix",
      "pattern": "quality.",
      "domain": "site_quality_safety"
    },
    {
      "match_type": "prefix",
      "pattern": "safety.",
      "domain": "site_quality_safety"
    },
    {
      "match_type": "prefix",
      "pattern": "workspace.",
      "domain": "workspace_shell"
    },
    {
      "match_type": "prefix",
      "pattern": "my_work.",
      "domain": "workspace_shell"
    },
    {
      "match_type": "exact",
      "pattern": "default",
      "domain": "workspace_shell"
    },
    {
      "match_type": "contains",
      "pattern": "default",
      "domain": "workspace_shell"
    }
  ],
  "fallback_domain": "misc_domain"
}
