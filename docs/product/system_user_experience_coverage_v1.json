      "browser_evidence": true
    },
    {
      "id": "UX-J007",
      "role": "project_manager",
      "name": "材料入库单办理",
      "entry": "物资与分包 / 材料管理 / 入库单",
      "surface_type": "form",
      "page_mode": "form",
      "actions": ["打开入库单", "新建", "选择项目与材料", "填写数量", "保存"],
      "success_criteria": ["主对象和明细行关系清楚", "明细行编辑不挤压主操作区", "错误定位到具体字段或行"],
      "automated_evidence": ["verify.formal_business_operation_core_flow_smoke"],
      "browser_evidence": false
    },
    {
      "id": "UX-J008",
      "role": "project_manager",
      "name": "分包申请办理",
      "entry": "物资与分包 / 专业分包 / 分包申请",
      "surface_type": "form",
      "page_mode": "form",
      "actions": ["打开分包申请", "新建", "填写分包单位", "填写金额", "保存"],
      "success_criteria": ["供应商选择、项目范围和金额含义清楚", "状态下一步明确", "返回列表能找到刚保存记录"],
      "automated_evidence": ["verify.business_system.usability_readiness"],
      "browser_evidence": false
    },
    {
      "id": "UX-J009",
      "role": "executive",
      "name": "经营驾驶舱查看风险和资金状态",
      "entry": "首页 / 经营驾驶舱",
      "surface_type": "dashboard",
      "page_mode": "dashboard",
      "actions": ["查看汇总", "识别风险", "下钻明细", "返回驾驶舱"],
      "success_criteria": ["10 秒内看清状态、风险、下一步", "指标名称是业务语言", "下钻路径可返回"],
      "automated_evidence": ["verify.business_system.usability_readiness"],
      "browser_evidence": true
    },
    {
      "id": "UX-J010",
      "role": "config_admin",
