      "surface_type": "form",
      "page_mode": "form",
      "actions": ["新建", "填写关键字段", "保存", "查看状态", "返回列表"],
      "success_criteria": ["第一屏明确单据对象、状态和主动作", "必填校验是业务语言", "保存反馈不遮挡继续操作"],
      "automated_evidence": ["verify.business_system.usability_readiness", "verify.p1.daily_business_form.usability.audit"],
      "browser_evidence": true
    },
    {
      "id": "UX-J005",
      "role": "finance",
      "name": "结算单查询和详情阅读",
      "entry": "财务中心 / 收付款办理 / 结算中心 / 结算单",
