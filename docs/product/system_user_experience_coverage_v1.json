      "surface_type": "support",
      "page_mode": "admin",
      "actions": ["查看系统健康", "查看发布版本", "导出诊断信息", "查看配置变更"],
      "success_criteria": ["支持入口只读", "健康状态和异常解释可读", "诊断包不要求用户理解服务器路径"],
      "automated_evidence": ["verify.business_system.usability_readiness.prod", "release.daily_dev.acceptance.publish"],
