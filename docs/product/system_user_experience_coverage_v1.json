      "surface_type": "admin",
      "page_mode": "admin",
      "actions": ["打开菜单配置", "查看可配置菜单", "拖拽排序", "保存", "刷新导航"],
      "success_criteria": ["配置面与主导航口径一致", "分组菜单与真实菜单职责清楚", "保存反馈与页面边界对齐"],
      "automated_evidence": ["verify.business_config.low_code_menu_navigation_alignment", "verify.business_config.config_workbench_operation_local_closeout"],
      "browser_evidence": true
    },
    {
      "id": "UX-J011",
      "role": "config_admin",
      "name": "表单设计器调整字段与分区",
      "entry": "配置中心 / 低代码系统配置 / 表单设计",
      "surface_type": "workspace",
      "page_mode": "admin",
      "actions": ["选择业务对象", "调整字段", "调整分区", "预览", "保存"],
      "success_criteria": ["配置对象明确", "配置动作不混入业务提交", "预览说明影响范围"],
