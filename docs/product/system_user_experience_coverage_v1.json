      "page_mode": "detail",
      "actions": ["搜索结算单", "打开详情", "查看金额和关联对象", "返回列表"],
      "success_criteria": ["详情页身份、金额、状态和来源清晰", "分区职责明确", "历史信息不干扰主阅读"],
      "automated_evidence": ["verify.business_system.usability_readiness"],
      "browser_evidence": false
    },
    {
      "id": "UX-J006",
      "role": "project_manager",
      "name": "施工日志录入",
