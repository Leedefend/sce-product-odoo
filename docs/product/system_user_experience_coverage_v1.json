{
  "version": "v1",
  "scope": "system_user_experience_coverage",
  "objective": "从真实用户使用视角覆盖登录、首页、导航、办理、查询、配置、支持和移动端体验。",
  "coverage_thresholds": {
    "min_roles": 6,
    "min_journeys": 10,
    "min_surface_types": 11,
    "min_page_modes": 6,
    "min_user_actions": 30,
    "min_automated_evidence": 8,
    "min_browser_evidence": 4
  },
  "roles": [
    {"code": "executive", "name": "领导", "primary_goal": "判断经营状态、风险和决策事项"},
    {"code": "project_manager", "name": "项目经理", "primary_goal": "完成施工、材料、分包、进度和现场事项办理"},
    {"code": "finance", "name": "财务人员", "primary_goal": "完成收付款、费用、保证金、发票、资金和结算处理"},
    {"code": "business_operator", "name": "经营人员", "primary_goal": "完成项目、投标、合同和基础资料维护"},
    {"code": "config_admin", "name": "配置管理员", "primary_goal": "调整菜单、表单、列表、搜索和发布配置"},
    {"code": "support_operator", "name": "支持人员", "primary_goal": "只读诊断系统健康、发布状态和用户问题"}
  ],
  "surface_types": ["login", "home", "navigation", "dashboard", "workspace", "list", "form", "detail", "admin", "support", "mobile"],
  "page_modes": ["dashboard", "workspace", "list", "form", "detail", "admin"],
  "journeys": [
    {
      "id": "UX-J001",
      "role": "business_operator",
      "name": "登录后进入业务首页并定位当前工作",
      "entry": "登录页 -> 我的工作",
      "surface_type": "home",
      "page_mode": "workspace",
      "actions": ["登录", "识别角色", "查看待办", "进入常用业务"],
      "success_criteria": ["5 秒内知道今天要处理什么", "首屏不暴露技术字段", "失败状态有明确解释"],
      "automated_evidence": ["verify.product.page_structure", "verify.portal.fe_smoke.host"],
      "browser_evidence": true
    },
    {
      "id": "UX-J002",
      "role": "business_operator",
      "name": "主导航进入项目台账并完成查询",
      "entry": "项目中心 / 项目管理 / 项目台账",
      "surface_type": "navigation",
      "page_mode": "list",
      "actions": ["展开导航", "打开列表", "搜索", "筛选", "分页", "刷新"],
      "success_criteria": ["导航路径与页面标题一致", "列表工具栏只承载查询控制", "空态和加载态可理解"],
      "automated_evidence": ["verify.product.navigation_boundary", "verify.product.page_structure"],
      "browser_evidence": true
    },
    {
      "id": "UX-J003",
      "role": "business_operator",
      "name": "收入合同台账查看并进入关联单据",
      "entry": "合同中心 / 收入合同台账",
      "surface_type": "list",
      "page_mode": "list",
      "actions": ["打开台账", "查看关键字段", "进入结算", "进入签证"],
      "success_criteria": ["先看到合同身份和状态", "关联入口不依赖技术 id", "返回路径稳定"],
      "automated_evidence": ["verify.formal_business_operation_capability_matrix", "verify.formal_business_operation_core_flow_smoke"],
      "browser_evidence": true
    },
    {
      "id": "UX-J004",
      "role": "finance",
      "name": "支付申请办理",
