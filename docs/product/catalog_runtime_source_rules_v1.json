{
  "version": "v1",
  "allowed_sources": ["catalog", "derived", "system", "fallback"],
  "rules": [
    {
      "id": "catalog-exact",
      "source": "catalog",
      "match_type": "catalog_exact",
      "pattern": "*",
      "reason": "listed in scene_catalog export"
    },
    {
      "id": "derived-pkg",
      "source": "derived",
      "match_type": "contains",
      "pattern": "__pkg",
      "reason": "derived scene variant generated by package suffix"
    },
    {
      "id": "system-default",
      "source": "system",
      "match_type": "contains",
      "pattern": "default",
      "reason": "system shell/default scene family"
    },
    {
      "id": "system-runtime-prefix-projects",
      "source": "system",
      "match_type": "prefix",
      "pattern": "projects.",
      "reason": "runtime system scene outside contract snapshot subset"
    },
    {
      "id": "system-runtime-prefix-finance",
      "source": "system",
      "match_type": "prefix",
      "pattern": "finance.",
      "reason": "runtime system scene outside contract snapshot subset"
    },
    {
      "id": "system-runtime-prefix-cost",
      "source": "system",
      "match_type": "prefix",
      "pattern": "cost.",
      "reason": "runtime system scene outside contract snapshot subset"
    },
    {
      "id": "system-runtime-prefix-portal",
      "source": "system",
      "match_type": "prefix",
      "pattern": "portal.",
      "reason": "runtime system scene outside contract snapshot subset"
    },
    {
      "id": "system-runtime-prefix-data",
      "source": "system",
      "match_type": "prefix",
      "pattern": "data.",
      "reason": "runtime system scene outside contract snapshot subset"
    }
  ],
  "fallback": {
    "source": "fallback",
    "reason": "runtime fallback/legacy naming path",
    "rule_id": "fallback-default"
  }
}
