          },
          {
            "type": "relation_card_block",
            "data": {
              "card_actions": [
                {
                  "key": "open",
                  "label": "查看详情",
                  "enabled": true,
                  "reason_code": "OK"
                },
                {
                  "key": "edit",
                  "label": "编辑",
                  "enabled": false,
                  "reason_code": "PERMISSION_DENIED"
                }
              ]
            }
          }
        ]
      }
    ]
