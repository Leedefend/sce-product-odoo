{
  "semantic_page": {
    "model": "project.project",
    "view_type": "form",
    "layout": "auto",
    "permission_verdicts": {
      "read": {"allowed": true, "reason_code": "OK", "reason": ""},
      "create": {"allowed": true, "reason_code": "OK", "reason": ""},
      "write": {"allowed": false, "reason_code": "PERMISSION_DENIED", "reason": "permission denied"},
      "unlink": {"allowed": false, "reason_code": "PERMISSION_DENIED", "reason": "permission denied"},
      "execute": {"allowed": true, "reason_code": "OK", "reason": ""}
