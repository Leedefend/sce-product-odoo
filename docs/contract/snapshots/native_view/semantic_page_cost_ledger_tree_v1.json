{
  "semantic_page": {
    "model": "cost.ledger",
    "view_type": "tree",
    "layout": "auto",
    "zones": [
      {
        "key": "action_zone",
        "blocks": [
          {
            "type": "action_bar_block",
            "data": {
              "search": {
                "filters": [
                  {
                    "key": "over_budget",
                    "label": "超预算"
                  }
                ],
                "group_by": [
                  {
                    "key": "project_id",
                    "label": "按项目"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "key": "detail_zone",
        "blocks": [
          {
            "type": "relation_table_block",
            "data": {
              "columns": [
                "name",
                "project_id",
                "planned_amount",
                "actual_amount",
                "variance_amount",
                "state"
              ]
            }
          }
        ]
      }
    ]
  }
}
