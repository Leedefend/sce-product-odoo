{
  "semantic_page": {
    "model": "cost.ledger",
    "view_type": "form",
    "layout": "auto",
    "zones": [
      {
        "key": "header_zone",
        "blocks": [
          {
            "type": "title_block",
            "data": {
              "title_field": "name",
              "state_field": "state"
            }
          },
          {
            "type": "action_bar_block",
            "data": {
              "actions": [
                {
                  "key": "save",
                  "label": "保存",
                  "enabled": true,
                  "reason_code": "OK"
                }
              ]
            }
          }
        ]
      },
      {
        "key": "detail_zone",
        "blocks": [
          {
            "type": "field_group_block",
            "data": {
              "fields": [
                "name",
                "project_id",
                "planned_amount",
                "actual_amount",
                "variance_amount",
                "state"
              ]
            }
          }
        ]
      }
    ]
  }
}
