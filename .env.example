# Public environment template. Copy this file to a local .env.<environment>
# file and replace every required placeholder outside Git.
ENV=<SET_ENVIRONMENT>
ENV_FILE=<SET_LOCAL_ENV_FILE>
COMPOSE_PROJECT_NAME=<SET_COMPOSE_PROJECT_NAME>

DB_USER=<SET_DATABASE_USER>
DB_PASSWORD=<SET_DATABASE_PASSWORD>
DB_NAME=<SET_DATABASE_NAME>
ADMIN_PASSWD=<SET_ODOO_MASTER_PASSWORD>
JWT_SECRET=<SET_LONG_RANDOM_JWT_SECRET>

ODOO_DBFILTER=<SET_ANCHORED_DATABASE_FILTER>
DB_DATA=<SET_DATABASE_VOLUME>
REDIS_DATA=<SET_REDIS_VOLUME>
ODOO_DATA=<SET_ODOO_VOLUME>

NGINX_PORT=<SET_NGINX_PORT>
ODOO_PORT=<SET_ODOO_PORT>
VITE_PLATFORM_ADMIN_DB=<SET_PLATFORM_ADMIN_DATABASE>

SC_LEGACY_FILE_ROOT=<SET_LOCAL_LEGACY_FILE_ROOT_IF_AUTHORIZED>
SC_LEGACY_ONLINE_MIRROR_ROOT=<SET_LOCAL_MIRROR_ROOT_IF_AUTHORIZED>
SC_LEGACY_FILE_ROOTS=<SET_AUTHORIZED_LEGACY_ROOTS>
SC_LEGACY_ONLINE_ATTACHMENT_FALLBACK=<SET_TRUE_OR_FALSE>
SC_LEGACY_FILE_HTTP_BASE=<SET_AUTHORIZED_HTTP_BASE>
