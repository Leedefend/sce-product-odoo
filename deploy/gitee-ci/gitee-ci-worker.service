[Unit]
Description=Gitee CI worker for sce-product-odoo
After=network-online.target gitee-webhook-ci.service
Wants=network-online.target

[Service]
Type=simple
User=gitee-ci
Group=gitee-ci
WorkingDirectory=/opt/gitee-ci/sce-product-odoo
EnvironmentFile=/etc/gitee-ci/sce-product-odoo-worker.env
ExecStart=/usr/bin/python3 /opt/gitee-ci/sce-product-odoo/gitee_webhook_ci.py --worker-only
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/gitee-ci /var/log/gitee-ci /var/lib/gitee-mirror/source.git
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
